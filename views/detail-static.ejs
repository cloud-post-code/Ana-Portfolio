<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title><%= item.title %> — <%= itemType === 'experience' ? 'Work Experience' : 'Project' %> — Ana Machuca</title>
  <meta name="description" content="<%= item.description %>" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="styles.css" />
</head>
<body class="page-detail">
  <div class="scroll-progress" id="scrollProgress"></div>
  <nav class="nav" id="nav" aria-label="Primary">
    <div class="nav__inner">
      <a href="index.html" class="nav__logo"><span class="nav__logo-mark">AM</span></a>
      <button type="button" class="nav__toggle" id="navToggle" aria-label="Open menu" aria-expanded="false" aria-controls="navLinks">
        <span class="nav__toggle-box" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <ul class="nav__links" id="navLinks">
        <li><a href="index.html">Home</a></li>
        <li><a href="index.html#about">About</a></li>
        <li><a href="index.html#contact" class="nav__cta">Hire me</a></li>
      </ul>
    </div>
  </nav>

  <main class="detail">
    <div class="container">
      <article>
        <header class="detail__header">
          <a href="index.html<%= itemType === 'experience' ? '#brands' : '#projects' %>" class="detail__back">&larr; Back to portfolio</a>

          <div class="detail__header-info reveal-blur">
            <h1 class="detail__title"><%= item.title %></h1>
            <% if (item.subtitle) { %>
            <p class="detail__subtitle-line"><%= item.subtitle %></p>
            <% } %>
          </div>
        </header>

        <% (item.deliverables || []).forEach(function(del) { %>
        <section class="detail__deliverable reveal-blur" aria-labelledby="<%= del.id %>-heading">
          <div class="detail__deliverable-heading<%= del.description ? ' detail__deliverable-heading--has-about' : '' %>">
            <div class="detail__deliverable-heading-text">
              <h2 id="<%= del.id %>-heading" class="detail__deliverable-title"><%= del.title %></h2>
              <% if (del.subtitle) { %>
              <p class="detail__deliverable-subtitle"><%= del.subtitle %></p>
              <% } %>
            </div>
            <% if (del.description) { %>
            <button
              type="button"
              class="detail__about-toggle"
              aria-expanded="false"
              aria-controls="about-<%= del.id %>"
            >
              <span class="detail__about-toggle-label">About</span>
              <span class="detail__about-toggle-icon" aria-hidden="true">+</span>
            </button>
            <% } %>
          </div>
          <div class="detail__deliverable-layout<%= del.description ? ' detail__deliverable-layout--has-about' : '' %>">
            <% if (del.media && del.media.length > 0) { %>
            <%
              var cols = del.gridColumns;
              if ((cols == null || cols === '') && del.galleryClass && String(del.galleryClass).indexOf('farout-social') >= 0) cols = '3';
              cols = cols != null && cols !== '' ? String(cols) : '';
              var galleryMod = (cols === '1' || cols === '2' || cols === '3' || cols === '4') ? (' detail__gallery--cols-' + cols) : '';
            %>
            <div class="detail__deliverable-media">
              <div class="detail__gallery<%= galleryMod %>">
                <% del.media.forEach(function(m) { %>
                  <% if (m.type === 'image') { %>
                <img src="<%= m.src %>" alt="<%= m.alt %>" loading="lazy" />
                  <% } else if (m.type === 'video-hover') { %>
                <div class="detail__video-hover">
                  <video class="detail__video-hover__media" muted playsinline loop preload="metadata" aria-label="<%= m.alt %>">
                    <source src="<%= m.src %>" type="video/mp4" />
                  </video>
                </div>
                  <% } else if (m.type === 'video-still') { %>
                <video class="detail__slide-still" muted playsinline preload="metadata" disablePictureInPicture aria-label="<%= m.alt %>">
                  <source src="<%= m.src %>" type="video/mp4" />
                </video>
                  <% } %>
                <% }); %>
              </div>
            </div>
            <% } %>
            <% if (del.description) { %>
            <aside class="detail__deliverable-about" aria-label="About this project" hidden>
              <div id="about-<%= del.id %>" class="detail__deliverable-copy">
                <p class="detail__deliverable-desc"><%= del.description %></p>
              </div>
            </aside>
            <% } %>
          </div>
        </section>
        <% }); %>

        <div class="detail__body detail__body--wide reveal-blur" style="margin-top: clamp(2rem, 4vw, 3rem);">
          <p><a href="mailto:Anitamachuca2373@gmail.com?subject=Role%20inquiry" class="btn btn--primary">Contact me about a role</a></p>
        </div>
      </article>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p class="footer__brand">Ana Machuca</p>
      <p class="footer__tagline">Humanizing Brands — One Story at a Time</p>
      <p class="footer__copy">&copy; 2026 Ana Machuca. Crafted with intention.</p>
    </div>
  </footer>
  <script src="main.js"></script>
</body>
</html>
