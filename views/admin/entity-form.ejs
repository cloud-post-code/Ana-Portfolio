<%
var openAdvanced = false;
if (!isNew && item) {
  openAdvanced = (
    (entity === 'projects' && item.projectType === 'personal') ||
    !!item.hidden
  );
}
var nDel = (!isNew && item && item.deliverables) ? item.deliverables.length : 0;
var openDeliverables = nDel > 0;
var adminTitle = isNew
  ? (entity === 'experiences' ? 'New Work Experience' : (typeof initialProjectType !== 'undefined' && initialProjectType === 'personal' ? 'New Personal Project' : 'New Client Project'))
  : ('Edit: ' + item.title);
%>
<%- include('layout-top', { adminTitle: adminTitle }) %>

<form id="entityForm" class="admin__form" data-entity="<%= entity %>" data-id="<%= isNew ? '' : item.id %>" data-is-new="<%= isNew %>">
  <!-- Essentials (single column) -->
  <div class="admin__form-grid">
    <div class="admin__form-group admin__form-group--full">
      <label>Title</label>
      <input type="text" name="title" value="<%= isNew ? '' : item.title %>" required />
    </div>

    <div class="admin__form-group admin__form-group--full">
      <label>Subtitle</label>
      <input type="text" name="subtitle" value="<%= isNew ? '' : (item.subtitle || '') %>" placeholder="e.g. Marketing Lead for E-commerce Platform Start Up" />
    </div>

    <div class="admin__form-group admin__form-group--full">
      <label>Description / Lead Text</label>
      <textarea name="description" rows="3"><%= isNew ? '' : item.description %></textarea>
    </div>

    <% if (entity === 'projects') { %>
    <div class="admin__form-group admin__form-group--full">
      <label>Tags (comma-separated, shown below "View Details" on the tile)</label>
      <input type="text" name="tags" value="<%= isNew ? '' : ((item.tags || []).join(', ')) %>" placeholder="e.g. Branding, Web Design, Print" />
    </div>
    <%
      var defaultProjectType = 'client';
      if (isNew && typeof initialProjectType !== 'undefined' && initialProjectType === 'personal') defaultProjectType = 'personal';
      var projectTypeVal = isNew ? defaultProjectType : ((item.projectType === 'personal') ? 'personal' : 'client');
    %>
    <div class="admin__form-group admin__form-group--full">
      <label>Project section</label>
      <select name="projectType">
        <option value="client"<%= projectTypeVal === 'client' ? ' selected' : '' %>>Client project (homepage: Client Projects)</option>
        <option value="personal"<%= projectTypeVal === 'personal' ? ' selected' : '' %>>Personal project (homepage: Personal Projects)</option>
      </select>
    </div>
    <% } %>

    <div class="admin__form-group admin__form-group--full">
      <label>Logo</label>
      <div class="admin__file-input">
        <input type="text" name="logo" value="<%= isNew ? '' : item.logo %>" placeholder="Path or upload" />
        <input type="file" accept="image/*" onchange="uploadFile(this, 'logo')" />
        <button type="button" class="admin__btn admin__btn--small" onclick="this.previousElementSibling.click()">Upload</button>
      </div>
      <% if (!isNew && item.logo) { %>
      <img src="/<%= item.logo %>" class="admin__preview-thumb" alt="Current logo" />
      <% } %>
    </div>

    <div class="admin__form-group admin__form-group--full">
      <label>Hover logo (shown when hovering the tile)</label>
      <div class="admin__file-input">
        <input type="text" name="logoHover" value="<%= isNew ? '' : (item.logoHover || '') %>" placeholder="Path or upload (optional)" />
        <input type="file" accept="image/*" onchange="uploadFile(this, 'logoHover')" />
        <button type="button" class="admin__btn admin__btn--small" onclick="this.previousElementSibling.click()">Upload</button>
      </div>
      <% if (!isNew && item.logoHover) { %>
      <img src="/<%= item.logoHover %>" class="admin__preview-thumb" alt="Current hover logo" />
      <% } %>
    </div>

    <% if (entity === 'experiences') { %>
    <div class="admin__form-group admin__form-group--full">
      <label>Role / Job Title</label>
      <input type="text" name="role" value="<%= isNew ? '' : item.role %>" placeholder="e.g. Marketing Intern" />
    </div>

    <div class="admin__form-group admin__form-group--full">
      <label>Date Range</label>
      <input type="text" name="dateRange" value="<%= isNew ? '' : item.dateRange %>" placeholder="e.g. Nov 2025 – Present" />
    </div>
    <% } %>
  </div>

  <details class="admin__advanced"<%= openAdvanced ? ' open' : '' %>>
    <summary>More options</summary>
    <div class="admin__advanced-body">
      <div class="admin__form-grid">
        <div class="admin__form-group">
          <label>Display Order</label>
          <input type="number" name="order" value="<%= isNew ? '' : item.order %>" min="1" />
        </div>

        <div class="admin__form-group admin__form-group--check">
          <label><input type="checkbox" name="hidden" <%= !isNew && item.hidden ? 'checked' : '' %> /> Hidden from public site</label>
        </div>
      </div>
    </div>
  </details>

  <details class="admin__advanced admin__advanced--deliverables"<%= openDeliverables ? ' open' : '' %>>
    <summary class="admin__advanced-summary--row">
      <span>Sub-groups (Deliverables)</span>
      <button type="button" class="admin__btn admin__btn--primary admin__btn--small" onclick="event.stopPropagation(); addDeliverable();">+ Add Sub-group</button>
    </summary>
    <section class="admin__deliverables">
      <div id="deliverablesList">
        <% if (!isNew && item.deliverables) { item.deliverables.forEach(function(del, dIdx) { %>
        <%
          var delCols = del.gridColumns;
          if (delCols == null || delCols === '') {
            if (del.galleryClass && String(del.galleryClass).indexOf('farout-social') >= 0) delCols = '3';
            else delCols = '';
          }
          delCols = String(delCols);
        %>
        <div class="admin__deliverable" data-del-id="<%= del.id %>">
          <div class="admin__deliverable-header">
            <span class="admin__deliverable-drag" title="Drag to reorder">&#9776;</span>
            <h3 class="admin__deliverable-label">Sub-group <%= dIdx + 1 %></h3>
            <button type="button" class="admin__btn admin__btn--small admin__btn--danger" onclick="removeDeliverable(this)">Remove</button>
          </div>
          <div class="admin__form-grid">
            <div class="admin__form-group admin__form-group--full">
              <label>Title</label>
              <input type="text" name="del_title" value="<%= del.title %>" />
            </div>
            <div class="admin__form-group admin__form-group--full">
              <label>Subtitle</label>
              <input type="text" name="del_subtitle" value="<%= del.subtitle || '' %>" placeholder="Optional line under the section title" />
            </div>
            <div class="admin__form-group admin__form-group--full">
              <label>Description</label>
              <textarea name="del_description" rows="2"><%= del.description %></textarea>
            </div>
            <div class="admin__form-group">
              <label>Grid columns</label>
              <select name="del_gridColumns">
                <option value="" <%= delCols === '' ? 'selected' : '' %>>Auto</option>
                <option value="1" <%= delCols === '1' ? 'selected' : '' %>>1</option>
                <option value="2" <%= delCols === '2' ? 'selected' : '' %>>2</option>
                <option value="3" <%= delCols === '3' ? 'selected' : '' %>>3</option>
                <option value="4" <%= delCols === '4' ? 'selected' : '' %>>4</option>
              </select>
            </div>
          </div>

          <div class="admin__media-section">
            <div class="admin__section-header">
              <h4>Media</h4>
              <div>
                <input type="file" accept="image/*,video/*" multiple onchange="uploadMedia(this)" style="display:none" />
                <button type="button" class="admin__btn admin__btn--small" onclick="this.previousElementSibling.click()">Upload Files</button>
                <button type="button" class="admin__btn admin__btn--small admin__btn--outline" onclick="addMediaManual(this)">+ Add Manually</button>
              </div>
            </div>
            <div class="admin__media-grid">
              <% if (del.media) { del.media.forEach(function(m) { %>
              <div class="admin__media-item">
                <span class="admin__media-drag" title="Drag to reorder">&#9776;</span>
                <div class="admin__media-preview">
                  <% if (m.type === 'image') { %>
                  <img src="/<%= m.src %>" alt="<%= m.alt %>" />
                  <% } else { %>
                  <video src="/<%= m.src %>" muted></video>
                  <% } %>
                </div>
                <div class="admin__media-fields">
                  <select name="media_type">
                    <option value="image" <%= m.type === 'image' ? 'selected' : '' %>>Image</option>
                    <option value="video-hover" <%= m.type === 'video-hover' ? 'selected' : '' %>>Video (hover play)</option>
                    <option value="video-still" <%= m.type === 'video-still' ? 'selected' : '' %>>Video (still frame)</option>
                  </select>
                  <input type="text" name="media_src" value="<%= m.src %>" placeholder="File path" />
                  <input type="text" name="media_alt" value="<%= m.alt %>" placeholder="Alt text" />
                </div>
                <button type="button" class="admin__media-remove" onclick="this.closest('.admin__media-item').remove()" title="Remove">&times;</button>
              </div>
              <% }); } %>
            </div>
          </div>
        </div>
        <% }); } %>
      </div>
    </section>
  </details>

  <div class="admin__form-actions">
    <button type="submit" class="admin__btn admin__btn--primary admin__btn--large">
      <%= isNew ? (entity === 'experiences' ? 'Create Experience' : 'Create Project') : 'Save Changes' %>
    </button>
    <a href="/admin" class="admin__btn admin__btn--outline admin__btn--large">Cancel</a>
    <% if (!isNew) { %>
    <button type="button" class="admin__btn admin__btn--danger admin__btn--outline admin__btn--large" onclick="deleteItem('<%= entity %>', '<%= item.id %>')"><%= entity === 'experiences' ? 'Delete experience' : 'Delete project' %></button>
    <% } %>
  </div>
</form>

<%- include('layout-bottom') %>
