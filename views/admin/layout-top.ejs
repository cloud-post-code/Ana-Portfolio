<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <script>
  (function () {
    if (!window.customElements || typeof window.customElements.define !== 'function') return;
    if (window.customElements.__anaDupDefineOk) return;
    window.customElements.__anaDupDefineOk = true;
    var original = window.customElements.define.bind(window.customElements);
    window.customElements.define = function (name, ctor, options) {
      try {
        return original(name, ctor, options);
      } catch (err) {
        var msg = err && (err.message || String(err));
        if (msg && /already been (defined|used)/i.test(msg)) return undefined;
        throw err;
      }
    };
  })();
  </script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof adminTitle !== 'undefined' ? adminTitle + ' — ' : '' %>Portfolio Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/admin.css" />
  <script>window.__ADMIN_ENHANCE_SECRET__ = <%- JSON.stringify(adminEnhanceSecret || '') %>;</script>
</head>
