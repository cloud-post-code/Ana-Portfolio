<%- include('layout-top', { adminTitle: 'Resume' }) %>

<section class="admin__section">
  <div class="admin__section-header">
    <div>
      <h2>Resume</h2>
      <p class="admin__section-lead">
        <strong>Public resume:</strong> upload a <strong>PDF</strong> or <strong>Word (.docx)</strong>. The app reads the document and stores one file, <code>public/resume.md</code>, which is what visitors download (plain Markdown). Edit the profile below manually; it is not filled from the upload.
        Optional <strong>baseline resume</strong> (<code>baseline-resume.docx</code>): click Regenerate below when <code>ANTHROPIC_API_KEY</code> is set—built from your profile and portfolio, not from the uploaded file.
        <strong>Job CRM pack:</strong> each row’s download is a ZIP with a tailored <strong>cover letter</strong> and <strong>job-specific tailored resume</strong> (both .docx), separate from the baseline document.
      </p>
    </div>
  </div>

  <div class="admin__card admin__resume-card">
    <% if (resumeFileExists && resume && resume.path) { %>
    <% var uploadBasename = (resume.path || '').replace(/^\//, ''); %>
    <div class="admin__resume-current">
      <p class="admin__resume-meta">
        <strong>Current file:</strong> <%= resume.originalFilename || uploadBasename || 'resume' %>
        <% if (resume.updatedAt) { %>
        <span class="admin__text-muted"> · Updated <%= new Date(resume.updatedAt).toLocaleString() %></span>
        <% } %>
      </p>
      <div class="admin__resume-actions">
        <a href="<%= resume.path %>" class="admin__btn admin__btn--outline" target="_blank" rel="noopener noreferrer">View file</a>
        <a href="<%= resume.path %>" class="admin__btn admin__btn--outline" download="<%= uploadBasename %>">Download</a>
        <button type="button" class="admin__btn admin__btn--danger" onclick="deleteResumeFile()">Remove resume</button>
      </div>
    </div>
    <% } else { %>
    <p class="admin__resume-empty">No public resume yet — visitors won’t see a download link until you add one.</p>
    <% } %>

    <div class="admin__resume-generated<%= baselineResumeFileExists ? '' : ' admin__resume-generated--empty' %>">
      <h3 class="admin__resume-generated__title">Baseline resume (.docx)</h3>
      <p class="admin__resume-generated__lead">
        Generated from your profile and portfolio (multi-page is OK). Job CRM downloads use a <em>separate</em> job-tailored resume. Regenerate after you edit the profile or checklists.
      </p>
      <% if (baselineResumeFileExists) { %>
      <p class="admin__resume-meta">
        <% var _bl = resume && (resume.baselineResumeUpdatedAt || resume.generatedResumeUpdatedAt); %>
        <% if (_bl) { %>
        <strong>Last built:</strong> <%= new Date(_bl).toLocaleString() %>
        <% } else { %>
        <strong>File on disk:</strong> <code><%= String(baselineResumePublicHref).replace(/^\//, '') %></code>
        <% } %>
      </p>
      <div class="admin__resume-actions">
        <a href="<%= baselineResumePublicHref %>" class="admin__btn admin__btn--outline" target="_blank" rel="noopener noreferrer">View / open</a>
        <a href="<%= baselineResumePublicHref %>" class="admin__btn admin__btn--outline" download="<%= String(baselineResumePublicHref).replace(/^\//, '') %>">Download</a>
      </div>
      <% } else { %>
      <p class="admin__text-muted admin__resume-generated__empty">No file yet. Save your profile below and click Regenerate (requires API key), or upload a PDF/Word above first—the public site uses <code>resume.md</code>, not this file.</p>
      <% } %>
      <button type="button" class="admin__btn admin__btn--primary admin__resume-regenerate" id="regenerateMasterResumeBtn" onclick="regenerateMasterResumeDocx()">Regenerate baseline resume</button>
    </div>

    <form class="admin__resume-form" id="resumeUploadForm" novalidate>
      <p class="admin__resume-upload-label"><%= resumeFileExists ? 'Replace file' : 'Add resume file' %></p>
      <p class="admin__resume-upload-meta">PDF or Word (.docx) · max 8 MB</p>
      <div class="admin__resume-upload-field">
      <input
        type="file"
        id="resumeFile"
        name="resume"
        accept="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.pdf,.docx"
        class="admin__resume-file-input-native"
        tabindex="-1"
        aria-label="Choose PDF or Word file (max 8 MB)"
      />
      <label
        for="resumeFile"
        class="admin__resume-dropzone"
        id="resumeDropzone"
        tabindex="0"
      >
        <span class="admin__visually-hidden">Choose PDF or Word file (max 8 MB)</span>
        <div class="admin__resume-dropzone__body">
          <p class="admin__resume-dropzone__lead">Drop your resume here</p>
          <p class="admin__resume-dropzone__or">or <span class="admin__resume-browse">click to browse</span></p>
          <p class="admin__resume-file-name" id="resumeFileName"><span class="admin__resume-file-name__placeholder">No file selected</span></p>
        </div>
      </label>
      </div>
      <div class="admin__resume-upload-actions">
        <button type="submit" class="admin__btn admin__btn--primary" id="resumeSubmitBtn" disabled><%= resumeFileExists ? 'Upload & replace' : 'Upload resume' %></button>
      </div>
    </form>
  </div>
</section>

<section class="admin__section" id="job-search-profile">
  <div class="admin__section-header">
    <div>
      <h2>Resume &amp; cover letter sources</h2>
      <p class="admin__section-lead">These fields feed the AI that writes your <strong>tailored resume</strong> (and support your cover letter profile). Save before downloading packs from the Job CRM.</p>
    </div>
    <div class="admin__section-header__actions">
      <a href="/api/job-search-profile" class="admin__btn admin__btn--outline admin__btn--small" target="_blank" rel="noopener noreferrer" title="Open raw JSON in a new tab">View profile JSON</a>
      <a href="/api/job-search-profile/download" class="admin__btn admin__btn--outline admin__btn--small" download="job-search-profile.json" title="Save profile as a file">Download profile JSON</a>
      <button type="button" class="admin__btn admin__btn--primary" id="saveJobProfileBtn" onclick="saveJobSearchProfile()">Save profile</button>
    </div>
  </div>

  <div class="admin__card">
    <h3 class="admin__subsection-title">Contact / header</h3>
    <div class="admin__form-grid">
      <div class="admin__form-group">
        <label class="admin__label" for="applicant_fullName">Full name</label>
        <input type="text" id="applicant_fullName" class="admin__resume-profile-input" value="<%= jobProfile.applicant.fullName %>" autocomplete="name" />
      </div>
      <div class="admin__form-group">
        <label class="admin__label" for="applicant_cityState">Location</label>
        <input type="text" id="applicant_cityState" class="admin__resume-profile-input" value="<%= jobProfile.applicant.cityState %>" placeholder="City, ST" />
      </div>
      <div class="admin__form-group">
        <label class="admin__label" for="applicant_phone">Phone</label>
        <input type="text" id="applicant_phone" class="admin__resume-profile-input" value="<%= jobProfile.applicant.phone %>" autocomplete="tel" />
      </div>
      <div class="admin__form-group">
        <label class="admin__label" for="applicant_email">Email</label>
        <input type="email" id="applicant_email" class="admin__resume-profile-input" value="<%= jobProfile.applicant.email %>" autocomplete="email" />
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="applicant_linkedIn">LinkedIn URL</label>
        <input type="url" id="applicant_linkedIn" class="admin__resume-profile-input" value="<%= jobProfile.applicant.linkedIn %>" placeholder="https://linkedin.com/in/..." />
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="applicant_portfolio">Portfolio URL</label>
        <input type="url" id="applicant_portfolio" class="admin__resume-profile-input" value="<%= jobProfile.applicant.portfolio %>" placeholder="https://..." />
      </div>
    </div>

    <h3 class="admin__subsection-title">Career narrative (cover letter + context)</h3>
    <div class="admin__form-grid">
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="headline">Headline</label>
        <input type="text" id="headline" class="admin__resume-profile-input" value="<%= jobProfile.headline %>" />
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="summary">Summary / goals</label>
        <textarea id="summary" class="admin__resume-profile-input" rows="6"><%= jobProfile.summary %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="keyDetails">Key details (one per line)</label>
        <textarea id="keyDetails" class="admin__resume-profile-input" rows="8" placeholder="Campaign and brand execution…"><% (jobProfile.keyDetails || []).forEach(function(line, i) { %><%= i > 0 ? '\n' : '' %><%= line %><% }) %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="targetSkillsToUse">Skills to emphasize (one per line)</label>
        <textarea id="targetSkillsToUse" class="admin__resume-profile-input" rows="6"><% (jobProfile.targetSkillsToUse || []).forEach(function(line, i) { %><%= i > 0 ? '\n' : '' %><%= line %><% }) %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="locationsPreferred">Locations preferred (one per line)</label>
        <textarea id="locationsPreferred" class="admin__resume-profile-input" rows="4"><% (jobProfile.locationsPreferred || []).forEach(function(line, i) { %><%= i > 0 ? '\n' : '' %><%= line %><% }) %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="roleTypesPreferred">Role types preferred (one per line)</label>
        <textarea id="roleTypesPreferred" class="admin__resume-profile-input" rows="4"><% (jobProfile.roleTypesPreferred || []).forEach(function(line, i) { %><%= i > 0 ? '\n' : '' %><%= line %><% }) %></textarea>
      </div>
    </div>

    <h3 class="admin__subsection-title">Education</h3>
    <div id="educationRows">
      <% var eduList = jobProfile.education && jobProfile.education.length ? jobProfile.education : [{ degree: '', dates: '', institution: '', location: '', bullets: '' }]; %>
      <% eduList.forEach(function(ed, idx) { %>
      <div class="admin__education-row" data-edu-index="<%= idx %>">
        <div class="admin__form-grid">
          <div class="admin__form-group">
            <label class="admin__label">Degree / certification</label>
            <input type="text" class="edu-degree admin__resume-profile-input" value="<%= ed.degree %>" />
          </div>
          <div class="admin__form-group">
            <label class="admin__label">Dates</label>
            <input type="text" class="edu-dates admin__resume-profile-input" value="<%= ed.dates %>" placeholder="Aug 2022 – May 2026" />
          </div>
          <div class="admin__form-group">
            <label class="admin__label">Institution</label>
            <input type="text" class="edu-institution admin__resume-profile-input" value="<%= ed.institution %>" />
          </div>
          <div class="admin__form-group">
            <label class="admin__label">School location</label>
            <input type="text" class="edu-location admin__resume-profile-input" value="<%= ed.location %>" />
          </div>
          <div class="admin__form-group admin__form-group--full">
            <label class="admin__label">Bullets (one per line)</label>
            <textarea class="edu-bullets admin__resume-profile-input" rows="3"><%= ed.bullets %></textarea>
          </div>
        </div>
        <button type="button" class="admin__btn admin__btn--small admin__btn--danger admin__education-remove" onclick="removeEducationRow(this)" aria-label="Remove education row">Remove</button>
        <hr class="admin__education-sep" />
      </div>
      <% }); %>
    </div>
    <button type="button" class="admin__btn admin__btn--outline" onclick="addEducationRow()">+ Add education</button>

    <h3 class="admin__subsection-title">Skills &amp; additional information</h3>
    <div class="admin__form-grid">
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="sk_technical">Technical skills</label>
        <textarea id="sk_technical" class="admin__resume-profile-input" rows="4"><%= jobProfile.skillsGroups.technical %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="sk_professional">Professional skills</label>
        <textarea id="sk_professional" class="admin__resume-profile-input" rows="4"><%= jobProfile.skillsGroups.professional %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="sk_certifications">Certifications / licenses</label>
        <textarea id="sk_certifications" class="admin__resume-profile-input" rows="3"><%= jobProfile.skillsGroups.certifications %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="sk_languages">Languages</label>
        <textarea id="sk_languages" class="admin__resume-profile-input" rows="3"><%= jobProfile.skillsGroups.languages %></textarea>
      </div>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="sk_toolsPlatforms">Tools / platforms</label>
        <textarea id="sk_toolsPlatforms" class="admin__resume-profile-input" rows="4"><%= jobProfile.skillsGroups.toolsPlatforms %></textarea>
      </div>
    </div>

    <h3 class="admin__subsection-title">Additional experience notes (optional)</h3>
    <div class="admin__form-group admin__form-group--full">
      <label class="admin__label" for="additionalExperienceNotes">Short notes for roles to keep brief or “additional experience”</label>
      <textarea id="additionalExperienceNotes" class="admin__resume-profile-input" rows="6"><%= jobProfile.additionalExperienceNotes %></textarea>
    </div>

    <h3 class="admin__subsection-title">Notes for AI (optional)</h3>
    <div class="admin__form-group admin__form-group--full">
      <label class="admin__label" for="resumeNotesForAi">Constraints or emphasis for tailored resume</label>
      <textarea id="resumeNotesForAi" class="admin__resume-profile-input" rows="5" maxlength="8000"><%= jobProfile.resumeNotesForAi %></textarea>
    </div>

    <h3 class="admin__subsection-title">Include in tailored resume</h3>
    <p class="admin__text-muted admin__resume-include-hint">Unchecked items are omitted from the AI resume for Job CRM downloads. Default is all visible (non-hidden) entries.</p>

    <div class="admin__resume-include-block">
      <h4 class="admin__resume-include-heading">Work experience</h4>
      <% if (!experiences.length) { %>
      <p class="admin__text-muted">No experiences yet — add some under <a href="/admin">Dashboard</a>.</p>
      <% } else { %>
      <ul class="admin__resume-include-list">
        <% experiences.forEach(function(e) { %>
        <% var expChecked = jobProfile.resumeIncludedExperienceIds == null ? !e.hidden : (jobProfile.resumeIncludedExperienceIds.indexOf(e.id) >= 0); %>
        <li>
          <label class="admin__resume-include-label">
            <input type="checkbox" class="resume-inc-exp" value="<%= e.id %>" <%= expChecked ? 'checked' : '' %> <%= e.hidden ? 'data-hidden="1"' : '' %> />
            <span><strong><%= e.title || e.company || 'Untitled' %></strong><% if (e.role) { %> — <%= e.role %><% } %><% if (e.hidden) { %> <span class="admin__text-muted">(hidden on site)</span><% } %></span>
          </label>
        </li>
        <% }); %>
      </ul>
      <% } %>
    </div>

    <div class="admin__resume-include-block">
      <h4 class="admin__resume-include-heading">Projects</h4>
      <% if (!projects.length) { %>
      <p class="admin__text-muted">No projects yet.</p>
      <% } else { %>
      <ul class="admin__resume-include-list">
        <% projects.forEach(function(p) { %>
        <% var projChecked = jobProfile.resumeIncludedProjectIds == null ? !p.hidden : (jobProfile.resumeIncludedProjectIds.indexOf(p.id) >= 0); %>
        <li>
          <label class="admin__resume-include-label">
            <input type="checkbox" class="resume-inc-proj" value="<%= p.id %>" <%= projChecked ? 'checked' : '' %> <%= p.hidden ? 'data-hidden="1"' : '' %> />
            <span><strong><%= p.title || 'Untitled' %></strong><% if (p.hidden) { %> <span class="admin__text-muted">(hidden on site)</span><% } %></span>
          </label>
        </li>
        <% }); %>
      </ul>
      <% } %>
    </div>
  </div>
</section>

<%- include('layout-bottom') %>

<script>
(function () {
  var form = document.getElementById('resumeUploadForm');
  if (!form) return;
  var input = document.getElementById('resumeFile');
  var dropzone = document.getElementById('resumeDropzone');
  var fileNameEl = document.getElementById('resumeFileName');
  var submitBtn = document.getElementById('resumeSubmitBtn');

  function setFileLabel(file) {
    if (!fileNameEl) return;
    if (!file) {
      fileNameEl.innerHTML = '<span class="admin__resume-file-name__placeholder">No file selected</span>';
      if (submitBtn) submitBtn.disabled = true;
      if (dropzone) dropzone.classList.remove('admin__resume-dropzone--has-file');
      return;
    }
    fileNameEl.textContent = file.name;
    if (submitBtn) submitBtn.disabled = false;
    if (dropzone) dropzone.classList.add('admin__resume-dropzone--has-file');
  }

  function isResumeUploadFile(file) {
    if (!file || !file.name) return false;
    var n = file.name.toLowerCase();
    return (
      n.slice(-4) === '.pdf' ||
      n.slice(-5) === '.docx' ||
      file.type === 'application/pdf' ||
      file.type === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
    );
  }

  function canAssignFilesViaDataTransfer() {
    if (!input || typeof DataTransfer === 'undefined' || typeof File === 'undefined') return false;
    try {
      var dt = new DataTransfer();
      dt.items.add(new File(['%PDF-1.4'], 'probe.pdf', { type: 'application/pdf' }));
      input.files = dt.files;
      var ok = input.files && input.files.length === 1;
      try {
        input.value = '';
      } catch (clearErr) {
        /* ignore */
      }
      return ok;
    } catch (err) {
      try {
        input.value = '';
      } catch (e2) {
        /* ignore */
      }
      return false;
    }
  }

  var dragDropAssignOk = canAssignFilesViaDataTransfer();

  function assignFileFromDrop(file) {
    if (!file || !isResumeUploadFile(file)) {
      if (typeof showToast === 'function') showToast('Please choose a PDF or Word (.docx) file.', 'error');
      return;
    }
    if (file.size > 8 * 1024 * 1024) {
      if (typeof showToast === 'function') showToast('File must be 8 MB or smaller.', 'error');
      return;
    }
    if (!dragDropAssignOk) {
      if (typeof showToast === 'function') {
        showToast('Drag-and-drop is not supported in this browser — use click to browse.', 'error');
      }
      return;
    }
    try {
      var dt = new DataTransfer();
      dt.items.add(file);
      input.files = dt.files;
    } catch (err) {
      if (typeof showToast === 'function') showToast('Could not use that file — try browse instead.', 'error');
      return;
    }
    setFileLabel(file);
  }

  if (input) {
    input.addEventListener('change', function () {
      var f = input.files && input.files[0];
      setFileLabel(f || null);
    });
  }

  if (dropzone && input) {
    dropzone.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        input.click();
      }
    });
    ['dragenter', 'dragover'].forEach(function (ev) {
      dropzone.addEventListener(ev, function (e) {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add('admin__resume-dropzone--active');
      });
    });
    ['dragleave', 'drop'].forEach(function (ev) {
      dropzone.addEventListener(ev, function (e) {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove('admin__resume-dropzone--active');
      });
    });
    dropzone.addEventListener('drop', function (e) {
      var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      assignFileFromDrop(f);
    });
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var f = input.files && input.files[0];
    if (!f) {
      if (typeof showToast === 'function') showToast('Choose a PDF or Word file to upload.', 'error');
      return;
    }
    if (!isResumeUploadFile(f)) {
      if (typeof showToast === 'function') showToast('Please choose a PDF or Word (.docx) file.', 'error');
      return;
    }
    var fd = new FormData();
    fd.append('resume', f);
    var btn = submitBtn || form.querySelector('button[type="submit"]');
    if (btn) btn.disabled = true;
    fetch('/api/resume', { method: 'POST', body: fd })
      .then(function (res) {
        var ct = (res.headers.get('Content-Type') || '').toLowerCase();
        if (!res.ok) {
          if (ct.indexOf('application/json') >= 0) {
            return res.json().then(function (j) {
              throw new Error(j.error || 'Upload failed');
            });
          }
          return res.text().then(function (t) {
            throw new Error((t && t.slice(0, 160)) || 'Upload failed');
          });
        }
        return res.json();
      })
      .then(function (data) {
        if (typeof showToast !== 'function') return;
        var detail =
          typeof data.markdownBytes === 'number'
            ? ' Saved as resume.md (' + data.markdownBytes + ' bytes).'
            : ' Saved as resume.md.';
        showToast('Resume saved.' + detail, 'success');
        setTimeout(function () {
          window.location.assign('/admin/resume#job-search-profile');
        }, 500);
      })
      .catch(function (err) {
        if (typeof showToast === 'function') showToast(err.message || 'Upload failed', 'error');
        else alert(err.message || 'Upload failed');
      })
      .finally(function () {
        if (btn) btn.disabled = !input.files || !input.files[0];
      });
  });
})();
function regenerateMasterResumeDocx() {
  var btn = document.getElementById('regenerateMasterResumeBtn');
  if (btn) btn.disabled = true;
  fetch('/api/resume/baseline-docx', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: '{}'
  })
    .then(function (res) {
      var ct = (res.headers.get('Content-Type') || '').toLowerCase();
      if (!res.ok) {
        if (ct.indexOf('application/json') >= 0) {
          return res.json().then(function (j) {
            throw new Error(j.error || 'Could not generate resume');
          });
        }
        throw new Error('Could not generate resume');
      }
      return res.json();
    })
    .then(function () {
      if (typeof showToast === 'function') showToast('Baseline resume (.docx) generated', 'success');
      setTimeout(function () {
        window.location.assign('/admin/resume#job-search-profile');
      }, 450);
    })
    .catch(function (err) {
      if (typeof showToast === 'function') showToast(err.message || 'Generation failed', 'error');
    })
    .finally(function () {
      if (btn) btn.disabled = false;
    });
}

function deleteResumeFile() {
  if (!confirm('Remove resume.md (and any legacy PDF/Word on disk) and the baseline .docx from the server?')) return;
  fetch('/api/resume', { method: 'DELETE' })
    .then(function (res) {
      if (!res.ok) throw new Error();
      return res.json();
    })
    .then(function () {
      if (typeof showToast === 'function') showToast('Resume removed', 'success');
      setTimeout(function () { location.reload(); }, 400);
    })
    .catch(function () {
      if (typeof showToast === 'function') showToast('Could not remove resume', 'error');
    });
}

function splitLines(text) {
  return String(text || '')
    .split(/\n+/)
    .map(function (s) { return s.trim(); })
    .filter(Boolean);
}

function collectEducation() {
  var rows = document.querySelectorAll('#educationRows .admin__education-row');
  var out = [];
  rows.forEach(function (row) {
    var degree = row.querySelector('.edu-degree');
    var dates = row.querySelector('.edu-dates');
    var institution = row.querySelector('.edu-institution');
    var location = row.querySelector('.edu-location');
    var bullets = row.querySelector('.edu-bullets');
    var o = {
      degree: degree ? degree.value.trim() : '',
      dates: dates ? dates.value.trim() : '',
      institution: institution ? institution.value.trim() : '',
      location: location ? location.value.trim() : '',
      bullets: bullets ? bullets.value.trim() : ''
    };
    if (o.degree || o.dates || o.institution || o.location || o.bullets) out.push(o);
  });
  return out;
}

function collectIncludedIds(className) {
  var boxes = document.querySelectorAll('.' + className);
  var ids = [];
  boxes.forEach(function (cb) {
    if (cb.checked) ids.push(cb.value);
  });
  return ids;
}

function saveJobSearchProfile() {
  var btn = document.getElementById('saveJobProfileBtn');
  if (btn) btn.disabled = true;
  var body = {
    applicant: {
      fullName: document.getElementById('applicant_fullName').value.trim(),
      email: document.getElementById('applicant_email').value.trim(),
      phone: document.getElementById('applicant_phone').value.trim(),
      cityState: document.getElementById('applicant_cityState').value.trim(),
      linkedIn: document.getElementById('applicant_linkedIn').value.trim(),
      portfolio: document.getElementById('applicant_portfolio').value.trim()
    },
    headline: document.getElementById('headline').value.trim(),
    summary: document.getElementById('summary').value.trim(),
    keyDetails: splitLines(document.getElementById('keyDetails').value),
    targetSkillsToUse: splitLines(document.getElementById('targetSkillsToUse').value),
    locationsPreferred: splitLines(document.getElementById('locationsPreferred').value),
    roleTypesPreferred: splitLines(document.getElementById('roleTypesPreferred').value),
    education: collectEducation(),
    skillsGroups: {
      technical: document.getElementById('sk_technical').value.trim(),
      professional: document.getElementById('sk_professional').value.trim(),
      certifications: document.getElementById('sk_certifications').value.trim(),
      languages: document.getElementById('sk_languages').value.trim(),
      toolsPlatforms: document.getElementById('sk_toolsPlatforms').value.trim()
    },
    additionalExperienceNotes: document.getElementById('additionalExperienceNotes').value.trim(),
    resumeNotesForAi: document.getElementById('resumeNotesForAi').value.trim(),
    resumeIncludedExperienceIds: collectIncludedIds('resume-inc-exp'),
    resumeIncludedProjectIds: collectIncludedIds('resume-inc-proj')
  };

  fetch('/api/job-search-profile', {
    method: 'PUT',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body)
  })
    .then(function (res) {
      if (!res.ok) return res.json().then(function (j) { throw new Error(j.error || 'Save failed'); });
      return res.json();
    })
    .then(function () {
      if (typeof showToast === 'function') showToast('Profile saved', 'success');
    })
    .catch(function (err) {
      if (typeof showToast === 'function') showToast(err.message || 'Save failed', 'error');
      else alert(err.message || 'Save failed');
    })
    .finally(function () {
      if (btn) btn.disabled = false;
    });
}

function addEducationRow() {
  var wrap = document.getElementById('educationRows');
  if (!wrap) return;
  var div = document.createElement('div');
  div.className = 'admin__education-row';
  div.innerHTML =
    '<div class="admin__form-grid">' +
    '<div class="admin__form-group"><label class="admin__label">Degree / certification</label><input type="text" class="edu-degree admin__resume-profile-input" value="" /></div>' +
    '<div class="admin__form-group"><label class="admin__label">Dates</label><input type="text" class="edu-dates admin__resume-profile-input" value="" /></div>' +
    '<div class="admin__form-group"><label class="admin__label">Institution</label><input type="text" class="edu-institution admin__resume-profile-input" value="" /></div>' +
    '<div class="admin__form-group"><label class="admin__label">School location</label><input type="text" class="edu-location admin__resume-profile-input" value="" /></div>' +
    '<div class="admin__form-group admin__form-group--full"><label class="admin__label">Bullets (one per line)</label><textarea class="edu-bullets admin__resume-profile-input" rows="3"></textarea></div>' +
    '</div>' +
    '<button type="button" class="admin__btn admin__btn--small admin__btn--danger admin__education-remove" onclick="removeEducationRow(this)">Remove</button>' +
    '<hr class="admin__education-sep" />';
  wrap.appendChild(div);
}

function removeEducationRow(btn) {
  var row = btn.closest('.admin__education-row');
  var wrap = document.getElementById('educationRows');
  if (!row || !wrap) return;
  if (wrap.querySelectorAll('.admin__education-row').length <= 1) {
    row.querySelectorAll('input, textarea').forEach(function (el) { el.value = ''; });
    return;
  }
  row.remove();
}
</script>
<script>
(function () {
  function fitResumeProfileTextareas() {
    var nodes = document.querySelectorAll('textarea.admin__resume-profile-input');
    var cap = typeof window !== 'undefined' ? Math.round(window.innerHeight * 0.62) : 520;
    nodes.forEach(function (el) {
      el.style.height = 'auto';
      var h = el.scrollHeight;
      if (h > cap) h = cap;
      el.style.height = h + 'px';
      el.style.overflowY = h >= cap ? 'auto' : 'hidden';
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fitResumeProfileTextareas);
  } else {
    fitResumeProfileTextareas();
  }
  window.addEventListener('load', fitResumeProfileTextareas);
})();
</script>
