<%- include('layout-top', { adminTitle: 'Resume' }) %>

<section class="admin__section">
  <div class="admin__section-header">
    <div>
      <h2>Resume</h2>
      <p class="admin__section-lead">Upload your resume, manage optional <strong>profile notes</strong> on a separate page (each note stored separately), paste the job posting, then run <strong>Tailor with AI</strong> and optionally <strong>generate a cover letter</strong>. Tailored resume and cover letter are previews plus <strong>Word (.docx)</strong> downloads — not stored on the server. Your resume file and profile notes persist until you remove them.</p>
    </div>
  </div>

  <div class="admin__card admin__resume-card">
    <% if (resumeFileExists && resume && resume.path) { %>
    <% var uploadBasename = (resume.path || '').replace(/^\//, ''); %>
    <div class="admin__resume-current">
      <p class="admin__resume-meta">
        <strong>Current resume:</strong> <%= resume.originalFilename || uploadBasename || 'resume' %>
        <% if (resume.updatedAt) { %>
        <span class="admin__text-muted"> · Uploaded <%= new Date(resume.updatedAt).toLocaleString() %></span>
        <% } %>
      </p>
      <div class="admin__resume-actions">
        <button type="button" class="admin__btn admin__btn--danger" onclick="deleteResumeFile()">Remove resume</button>
      </div>
    </div>
    <% } else { %>
    <p class="admin__resume-empty">Upload a PDF or Word resume below to get started. You need a stored resume before you can tailor it for a role.</p>
    <% } %>

    <h3 class="admin__resume-step-title">Step 1 — Upload your resume</h3>
    <form class="admin__resume-form" id="resumeUploadForm" novalidate>
      <p class="admin__resume-upload-meta">PDF or Word (.docx) · max 8 MB</p>
      <div class="admin__resume-upload-field">
      <input
        type="file"
        id="resumeFile"
        name="resume"
        accept="application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,.pdf,.docx"
        class="admin__resume-file-input-native"
        tabindex="-1"
        aria-label="Choose PDF or Word file (max 8 MB)"
      />
      <label
        for="resumeFile"
        class="admin__resume-dropzone"
        id="resumeDropzone"
        tabindex="0"
      >
        <span class="admin__visually-hidden">Choose PDF or Word file (max 8 MB)</span>
        <div class="admin__resume-dropzone__body">
          <p class="admin__resume-dropzone__lead">Drop your resume here</p>
          <p class="admin__resume-dropzone__or">or <span class="admin__resume-browse">click to browse</span></p>
          <p class="admin__resume-file-name" id="resumeFileName"><span class="admin__resume-file-name__placeholder">No file selected</span></p>
        </div>
      </label>
      </div>
      <div class="admin__resume-upload-actions">
        <button type="submit" class="admin__btn admin__btn--primary" id="resumeSubmitBtn" disabled><%= resumeFileExists ? 'Upload & replace' : 'Upload resume' %></button>
      </div>
    </form>

    <h3 class="admin__resume-step-title">Step 1.5 — Profile notes</h3>
    <p class="admin__text-muted" style="margin-bottom:0.75rem;font-size:0.88rem;line-height:1.45;">Store multiple notes separately (add, Enhance with GPT, delete on the Profile notes page). All saved notes are combined when you tailor your resume or generate a cover letter. They are <strong>not</strong> deleted when you remove the uploaded resume file.</p>
    <div class="admin__resume-actions" style="flex-wrap:wrap;gap:0.75rem;align-items:center;margin-bottom:1rem;">
      <a href="/admin/resume/profile-notes" class="admin__btn admin__btn--outline">Open Profile notes</a>
      <span class="admin__text-muted" style="font-size:0.88rem;"><strong><%= typeof profileNotesCount !== 'undefined' ? profileNotesCount : 0 %></strong> saved note<%= (typeof profileNotesCount !== 'undefined' && profileNotesCount === 1) ? '' : 's' %></span>
    </div>

    <h3 class="admin__resume-step-title">Step 2 — Job details</h3>
    <% if (!hasLlmKey) { %>
    <p class="admin__text-muted" style="margin-bottom:1rem;">Set <code>OPENAI_API_KEY</code> or <code>ANTHROPIC_API_KEY</code> on the server to enable AI tailoring.</p>
    <% } %>
    <div class="admin__form-group admin__form-group--full">
      <label class="admin__label" for="tailorJobDesc">Job description <span class="admin__text-muted">(required)</span></label>
      <textarea
        id="tailorJobDesc"
        class="admin__resume-profile-input"
        rows="10"
        placeholder="Paste the full job posting — role, requirements, responsibilities, company…"
      ></textarea>
    </div>
    <div class="admin__form-group admin__form-group--full">
      <label class="admin__label" for="tailorDetails">Instructions for this job <span class="admin__text-muted">(optional)</span></label>
      <textarea
        id="tailorDetails"
        class="admin__resume-profile-input"
        rows="4"
        placeholder="e.g. Emphasise analytics for this posting. Tone: confident but warm."
      ></textarea>
    </div>

    <% if (hasLlmKey && resumeTailorModels && resumeTailorModels.length) { %>
    <div class="admin__form-group admin__form-group--full">
      <label class="admin__label" for="tailorModelSelect">AI model</label>
      <select id="tailorModelSelect" class="admin__resume-profile-input admin__resume-model-select" aria-describedby="tailorModelHelp">
        <% resumeTailorModels.forEach(function (opt) { %>
        <option value="<%= opt.value %>"<%= resumeTailorDefault && opt.value === resumeTailorDefault.value ? ' selected' : '' %>><%= opt.label %></option>
        <% }); %>
      </select>
      <p id="tailorModelHelp" class="admin__text-muted" style="margin:0.35rem 0 0;font-size:0.82rem;">Choose OpenAI or Anthropic (if both are configured). Selection is remembered for this browser session.</p>
    </div>
    <% } %>

    <h3 class="admin__resume-step-title">Step 3 — Tailored resume &amp; cover letter</h3>
    <p class="admin__text-muted" style="margin:0 0 0.75rem;font-size:0.88rem;line-height:1.45;"><strong>Tailored resume:</strong> AI rewrites bullets and structure to fit the posting (grounded in your resume and profile notes). <strong>Cover letter:</strong> optional short narrative — same job text; not saved on the server.</p>
    <div class="admin__resume-actions admin__resume-actions--tailor-pair" style="margin-bottom:1rem;">
      <button
        type="button"
        class="admin__btn admin__btn--primary"
        id="tailorRunBtn"
        onclick="runResumeTailor(false)"
        <%= hasLlmKey ? '' : 'disabled title="Set OPENAI_API_KEY or ANTHROPIC_API_KEY on the server"' %>
      >Tailor with AI</button>
      <button
        type="button"
        class="admin__btn admin__btn--primary"
        id="tailorWithCoverBtn"
        onclick="runResumeTailor(true)"
        <%= hasLlmKey ? '' : 'disabled title="Set OPENAI_API_KEY or ANTHROPIC_API_KEY on the server"' %>
      >Tailor with AI + Cover letter</button>
      <span id="tailorStatus" class="admin__text-muted" style="margin-left:.75rem;flex:1;min-width:8rem;"></span>
    </div>

    <div id="tailorResultWrap" style="display:none;">
      <p class="admin__text-muted" style="margin:0 0 0.75rem;font-size:0.85rem;">Preview only — not saved on the server. Use the button below if you edited the text or the automatic download was blocked.</p>
      <div class="admin__form-group admin__form-group--full">
        <label class="admin__label" for="tailorResultMd">Refined tailored resume <span class="admin__text-muted">(Markdown — editable; export as Word)</span></label>
        <textarea
          id="tailorResultMd"
          class="admin__resume-profile-input"
          rows="22"
          placeholder="After tailoring, your Word file downloads automatically. The preview appears here for quick edits."
        ></textarea>
        <p class="admin__line-budget" id="tailorResultLineBudget" aria-live="polite">Lines: <span id="tailorResultLineCount">0</span> / <%= maxResumePageLines %></p>
      </div>
      <div class="admin__resume-actions">
        <button type="button" class="admin__btn admin__btn--outline" onclick="downloadTailoredResume()">
          Download Word again (.docx)
        </button>
      </div>
    </div>

    <div class="admin__resume-cover-letter" style="margin-top:1.75rem;padding-top:1.5rem;border-top:1px solid var(--admin-border);">
      <h4 class="admin__resume-substep-title">Cover letter</h4>
      <p class="admin__text-muted" style="margin:0 0 0.75rem;font-size:0.88rem;line-height:1.45;">Uses the job description above, your stored resume, profile notes, and optional per-job instructions. Preview only — download as Word if you like; nothing is stored on the server.</p>
      <div class="admin__resume-actions" style="margin-bottom:0.75rem;">
        <button
          type="button"
          class="admin__btn admin__btn--primary"
          id="coverLetterRunBtn"
          onclick="runCoverLetter()"
          <%= hasLlmKey ? '' : 'disabled title="Set OPENAI_API_KEY or ANTHROPIC_API_KEY on the server"' %>
        >Generate cover letter</button>
        <span id="coverLetterStatus" class="admin__text-muted" style="margin-left:.75rem;"></span>
      </div>
      <div id="coverLetterWrap" style="display:none;">
        <div class="admin__form-group admin__form-group--full">
          <label class="admin__label" for="coverLetterMd">Cover letter <span class="admin__text-muted">(Markdown — editable)</span></label>
          <textarea
            id="coverLetterMd"
            class="admin__resume-profile-input"
            rows="16"
            placeholder="Generated text appears here. Edit as needed, then download as Word."
          ></textarea>
          <p class="admin__line-budget" id="coverLetterLineBudget" aria-live="polite">Lines: <span id="coverLetterLineCount">0</span> / <%= maxCoverLetterLines %></p>
        </div>
        <div class="admin__resume-actions">
          <button type="button" class="admin__btn admin__btn--outline" onclick="downloadCoverLetterDocx()">Download Word (.docx)</button>
          <button type="button" class="admin__btn admin__btn--outline" onclick="runCoverLetter()" id="coverLetterAgainBtn">Generate again</button>
        </div>
      </div>
    </div>
  </div>
</section>

<%- include('layout-bottom') %>

<script>
var MAX_RESUME_PAGE_LINES = <%= maxResumePageLines %>;
var MAX_COVER_LETTER_LINES = <%= maxCoverLetterLines %>;

function resumeLineCount(s) {
  s = String(s || '');
  if (!s) return 0;
  return s.split('\n').length;
}

function setLineBudgetEl(countEl, budgetEl, n, maxN) {
  if (countEl) countEl.textContent = String(n);
  if (budgetEl) {
    budgetEl.classList.toggle('admin__line-budget--over', n > maxN);
  }
}

function refreshTailorResultLineBudget() {
  var ta = document.getElementById('tailorResultMd');
  var n = resumeLineCount(ta ? ta.value : '');
  setLineBudgetEl(
    document.getElementById('tailorResultLineCount'),
    document.getElementById('tailorResultLineBudget'),
    n,
    MAX_RESUME_PAGE_LINES
  );
}

function refreshCoverLetterLineBudget() {
  var ta = document.getElementById('coverLetterMd');
  var n = resumeLineCount(ta ? ta.value : '');
  setLineBudgetEl(
    document.getElementById('coverLetterLineCount'),
    document.getElementById('coverLetterLineBudget'),
    n,
    MAX_COVER_LETTER_LINES
  );
}

function getTailorModelPayload() {
  var out = {};
  var modelSel = document.getElementById('tailorModelSelect');
  if (modelSel && modelSel.value) {
    var pipe = modelSel.value.indexOf('|');
    if (pipe > 0) {
      out.provider = modelSel.value.slice(0, pipe);
      out.model = modelSel.value.slice(pipe + 1);
    }
  }
  return out;
}

document.addEventListener('DOMContentLoaded', function () {
  var tailorTa = document.getElementById('tailorResultMd');
  if (tailorTa) {
    tailorTa.addEventListener('input', refreshTailorResultLineBudget);
  }
  var clTa = document.getElementById('coverLetterMd');
  if (clTa) {
    clTa.addEventListener('input', refreshCoverLetterLineBudget);
  }
});

function coverLetterDocxBasename() {
  var jobDescEl = document.getElementById('tailorJobDesc');
  var snippet = jobDescEl ? jobDescEl.value.trim().slice(0, 40).replace(/\s+/g, '-').replace(/[^a-zA-Z0-9\-]/g, '') : '';
  return 'cover-letter' + (snippet ? '-' + snippet : '');
}

/**
 * @param {{ fromTailorChain?: boolean }} opts - when true, skip standalone busy/locks (tailor flow owns buttons)
 * @returns {Promise<void>}
 */
function runCoverLetter(opts) {
  opts = opts || {};
  var fromChain = !!opts.fromTailorChain;

  var jobDesc = (document.getElementById('tailorJobDesc') || {}).value || '';
  var details = (document.getElementById('tailorDetails') || {}).value || '';
  var btn = document.getElementById('coverLetterRunBtn');
  var again = document.getElementById('coverLetterAgainBtn');
  var statusEl = document.getElementById('coverLetterStatus');
  var wrap = document.getElementById('coverLetterWrap');
  var resultTa = document.getElementById('coverLetterMd');

  if (!jobDesc.trim()) {
    if (!fromChain && typeof showToast === 'function') showToast('Paste a job description first.', 'error');
    return Promise.resolve();
  }

  if (!fromChain) {
    if (runCoverLetter._busy) return Promise.resolve();
    runCoverLetter._busy = true;
    if (btn) btn.disabled = true;
    if (again) again.disabled = true;
  }
  if (statusEl) statusEl.textContent = 'Writing cover letter\u2026';

  var payload = Object.assign(
    { jobDescription: jobDesc, additionalDetails: details },
    getTailorModelPayload()
  );

  return fetch('/api/resume/cover-letter', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
    .then(function (res) {
      var ct = (res.headers.get('Content-Type') || '').toLowerCase();
      if (ct.indexOf('application/json') >= 0) {
        return res.json().then(function (j) {
          return { ok: res.ok, j: j };
        });
      }
      return res.text().then(function (t) {
        return { ok: res.ok, j: { error: (t && t.slice(0, 200)) || 'Cover letter failed (' + res.status + ')' } };
      });
    })
    .then(function (o) {
      if (!o.ok) throw new Error((o.j && o.j.error) || 'Cover letter failed');
      var md = o.j.coverLetterMarkdown != null ? String(o.j.coverLetterMarkdown) : '';
      if (!String(md).trim()) {
        throw new Error('No cover letter text returned — try again.');
      }
      if (resultTa) resultTa.value = md;
      if (wrap) wrap.style.display = '';
      if (!fromChain && wrap) wrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      refreshCoverLetterLineBudget();
      if (statusEl) statusEl.textContent = 'Done \u00b7 ' + (o.j.model || '');
      if (typeof showToast === 'function') {
        showToast(
          fromChain
            ? 'Resume and cover letter are ready — previews below; not saved on the server.'
            : 'Cover letter ready — not saved on the server.',
          'success'
        );
      }
    })
    .catch(function (e) {
      if (statusEl && !fromChain) statusEl.textContent = '';
      if (typeof showToast === 'function') {
        showToast(e.message || 'Cover letter failed', 'error');
      }
      throw e;
    })
    .finally(function () {
      if (!fromChain) {
        runCoverLetter._busy = false;
        if (btn) btn.disabled = false;
        if (again) again.disabled = false;
      }
    });
}

function downloadCoverLetterDocx() {
  var resultTa = document.getElementById('coverLetterMd');
  var md = resultTa ? resultTa.value.trim() : '';
  if (!md) {
    if (typeof showToast === 'function') showToast('Generate a cover letter first.', 'error');
    return;
  }
  var filename = coverLetterDocxBasename();
  fetch('/api/resume/cover-letter/download', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ markdown: md, filename: filename })
  })
    .then(function (res) {
      if (!res.ok) {
        return res.json().then(function (j) {
          throw new Error(j.error || 'Download failed');
        });
      }
      return res.blob().then(function (blob) {
        var disposition = res.headers.get('Content-Disposition') || '';
        var m = /filename="([^"]+)"/.exec(disposition);
        return { blob: blob, fname: m ? m[1] : filename + '.docx' };
      });
    })
    .then(function (o) {
      var a = document.createElement('a');
      a.href = URL.createObjectURL(o.blob);
      a.download = o.fname;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(a.href);
      if (typeof showToast === 'function') showToast('Word document downloaded.', 'success');
    })
    .catch(function (e) {
      if (typeof showToast === 'function') showToast(e.message || 'Download failed', 'error');
    });
}

(function () {
  var sel = document.getElementById('tailorModelSelect');
  if (sel) {
    try {
      var saved = sessionStorage.getItem('resumeTailorModel');
      if (saved) {
        for (var i = 0; i < sel.options.length; i++) {
          if (sel.options[i].value === saved) {
            sel.selectedIndex = i;
            break;
          }
        }
      }
      sel.addEventListener('change', function () {
        try {
          sessionStorage.setItem('resumeTailorModel', sel.value);
        } catch (e) {
          /* ignore */
        }
      });
    } catch (e) {
      /* ignore */
    }
  }
})();
(function () {
  var form = document.getElementById('resumeUploadForm');
  if (!form) return;
  var input = document.getElementById('resumeFile');
  var dropzone = document.getElementById('resumeDropzone');
  var fileNameEl = document.getElementById('resumeFileName');
  var submitBtn = document.getElementById('resumeSubmitBtn');

  function setFileLabel(file) {
    if (!fileNameEl) return;
    if (!file) {
      fileNameEl.innerHTML = '<span class="admin__resume-file-name__placeholder">No file selected</span>';
      if (submitBtn) submitBtn.disabled = true;
      if (dropzone) dropzone.classList.remove('admin__resume-dropzone--has-file');
      return;
    }
    fileNameEl.textContent = file.name;
    if (submitBtn) submitBtn.disabled = false;
    if (dropzone) dropzone.classList.add('admin__resume-dropzone--has-file');
  }

  function isResumeUploadFile(file) {
    if (!file || !file.name) return false;
    var n = file.name.toLowerCase();
    return (
      n.slice(-4) === '.pdf' ||
      n.slice(-5) === '.docx' ||
      file.type === 'application/pdf' ||
      file.type === 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
    );
  }

  function canAssignFilesViaDataTransfer() {
    if (!input || typeof DataTransfer === 'undefined' || typeof File === 'undefined') return false;
    try {
      var dt = new DataTransfer();
      dt.items.add(new File(['%PDF-1.4'], 'probe.pdf', { type: 'application/pdf' }));
      input.files = dt.files;
      var ok = input.files && input.files.length === 1;
      try {
        input.value = '';
      } catch (clearErr) {
        /* ignore */
      }
      return ok;
    } catch (err) {
      try {
        input.value = '';
      } catch (e2) {
        /* ignore */
      }
      return false;
    }
  }

  var dragDropAssignOk = canAssignFilesViaDataTransfer();

  function assignFileFromDrop(file) {
    if (!file || !isResumeUploadFile(file)) {
      if (typeof showToast === 'function') showToast('Please choose a PDF or Word (.docx) file.', 'error');
      return;
    }
    if (file.size > 8 * 1024 * 1024) {
      if (typeof showToast === 'function') showToast('File must be 8 MB or smaller.', 'error');
      return;
    }
    if (!dragDropAssignOk) {
      if (typeof showToast === 'function') {
        showToast('Drag-and-drop is not supported in this browser — use click to browse.', 'error');
      }
      return;
    }
    try {
      var dt = new DataTransfer();
      dt.items.add(file);
      input.files = dt.files;
    } catch (err) {
      if (typeof showToast === 'function') showToast('Could not use that file — try browse instead.', 'error');
      return;
    }
    setFileLabel(file);
  }

  if (input) {
    input.addEventListener('change', function () {
      var f = input.files && input.files[0];
      setFileLabel(f || null);
    });
  }

  if (dropzone && input) {
    dropzone.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        input.click();
      }
    });
    ['dragenter', 'dragover'].forEach(function (ev) {
      dropzone.addEventListener(ev, function (e) {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.add('admin__resume-dropzone--active');
      });
    });
    ['dragleave', 'drop'].forEach(function (ev) {
      dropzone.addEventListener(ev, function (e) {
        e.preventDefault();
        e.stopPropagation();
        dropzone.classList.remove('admin__resume-dropzone--active');
      });
    });
    dropzone.addEventListener('drop', function (e) {
      var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
      assignFileFromDrop(f);
    });
  }

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    var f = input.files && input.files[0];
    if (!f) {
      if (typeof showToast === 'function') showToast('Choose a PDF or Word file to upload.', 'error');
      return;
    }
    if (!isResumeUploadFile(f)) {
      if (typeof showToast === 'function') showToast('Please choose a PDF or Word (.docx) file.', 'error');
      return;
    }
    var fd = new FormData();
    fd.append('resume', f);
    var btn = submitBtn || form.querySelector('button[type="submit"]');
    if (btn) btn.disabled = true;
    fetch('/api/resume', { method: 'POST', body: fd })
      .then(function (res) {
        var ct = (res.headers.get('Content-Type') || '').toLowerCase();
        if (!res.ok) {
          if (ct.indexOf('application/json') >= 0) {
            return res.json().then(function (j) {
              throw new Error(j.error || 'Upload failed');
            });
          }
          return res.text().then(function (t) {
            throw new Error((t && t.slice(0, 160)) || 'Upload failed');
          });
        }
        return res.json();
      })
      .then(function () {
        if (typeof showToast === 'function') showToast('Resume saved. You can tailor it below.', 'success');
        setTimeout(function () {
          window.location.assign('/admin/resume');
        }, 500);
      })
      .catch(function (err) {
        if (typeof showToast === 'function') showToast(err.message || 'Upload failed', 'error');
        else alert(err.message || 'Upload failed');
      })
      .finally(function () {
        if (btn) btn.disabled = !input.files || !input.files[0];
      });
  });
})();

function deleteResumeFile() {
  if (!confirm('Remove your stored resume from the server?')) return;
  fetch('/api/resume', { method: 'DELETE' })
    .then(function (res) {
      if (!res.ok) throw new Error();
      return res.json();
    })
    .then(function () {
      if (typeof showToast === 'function') showToast('Resume removed', 'success');
      setTimeout(function () { location.reload(); }, 400);
    })
    .catch(function () {
      if (typeof showToast === 'function') showToast('Could not remove resume', 'error');
    });
}

/**
 * @param {boolean} alsoCoverLetter - if true, generate cover letter after tailored resume + Word download
 */
function runResumeTailor(alsoCoverLetter) {
  var jobDesc = (document.getElementById('tailorJobDesc') || {}).value || '';
  var details = (document.getElementById('tailorDetails') || {}).value || '';
  var btn = document.getElementById('tailorRunBtn');
  var btnCover = document.getElementById('tailorWithCoverBtn');
  var statusEl = document.getElementById('tailorStatus');
  var wrap = document.getElementById('tailorResultWrap');
  var resultTa = document.getElementById('tailorResultMd');

  if (!jobDesc.trim()) {
    if (typeof showToast === 'function') showToast('Paste a job description first.', 'error');
    return;
  }

  if (runResumeTailor._busy) return;
  runResumeTailor._busy = true;

  if (btn) btn.disabled = true;
  if (btnCover) btnCover.disabled = true;
  if (statusEl) statusEl.textContent = 'Tailoring with AI\u2026 this takes 15\u201330 seconds.';
  if (wrap) wrap.style.display = 'none';

  var tailorPayload = Object.assign({ jobDescription: jobDesc, additionalDetails: details }, getTailorModelPayload());

  fetch('/api/resume/tailor', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(tailorPayload)
  })
    .then(function (res) {
      var ct = (res.headers.get('Content-Type') || '').toLowerCase();
      if (ct.indexOf('application/json') >= 0) {
        return res.json().then(function (j) {
          return { ok: res.ok, j: j };
        });
      }
      return res.text().then(function (t) {
        return { ok: res.ok, j: { error: (t && t.slice(0, 200)) || 'Tailor failed (' + res.status + ')' } };
      });
    })
    .then(function (o) {
      if (!o.ok) throw new Error((o.j && o.j.error) || 'Tailor failed');
      var md = o.j.tailoredMarkdown != null ? String(o.j.tailoredMarkdown) : '';
      if (!String(md).trim()) {
        throw new Error('No tailored text returned — try again.');
      }
      if (resultTa) resultTa.value = md;
      refreshTailorResultLineBudget();
      if (wrap) wrap.style.display = '';
      if (wrap) wrap.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (statusEl) statusEl.textContent = 'Preparing Word download\u2026';
      return downloadTailoredResumeMarkdown(md, { skipSuccessToast: true })
        .then(function () {
          if (!alsoCoverLetter) {
            if (statusEl) statusEl.textContent = 'Done \u00b7 ' + (o.j.model || '');
            if (typeof showToast === 'function') {
              showToast('Word document downloaded to your device. Tailored text is not saved on the server.', 'success');
            }
            return;
          }
          if (statusEl) statusEl.textContent = 'Resume saved \u00b7 writing cover letter\u2026';
          return runCoverLetter({ fromTailorChain: true })
            .then(function () {
              if (statusEl) statusEl.textContent = 'Done \u00b7 resume + cover letter';
              var clWrap = document.getElementById('coverLetterWrap');
              if (clWrap) clWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            })
            .catch(function () {
              if (statusEl) {
                statusEl.textContent = 'Resume done \u00b7 cover letter failed — use Generate cover letter';
              }
            });
        })
        .catch(function (dlErr) {
          if (statusEl) {
            statusEl.textContent = 'Tailored \u00b7 auto-download failed — use Download Word again';
          }
          if (typeof showToast === 'function') {
            showToast((dlErr && dlErr.message) || 'Download failed', 'error');
          }
        });
    })
    .catch(function (e) {
      if (statusEl) statusEl.textContent = '';
      if (typeof showToast === 'function') showToast(e.message || 'Tailor failed', 'error');
    })
    .finally(function () {
      runResumeTailor._busy = false;
      if (btn) btn.disabled = false;
      if (btnCover) btnCover.disabled = false;
    });
}

function tailoredDocxBasename() {
  var jobDescEl = document.getElementById('tailorJobDesc');
  var snippet = jobDescEl ? jobDescEl.value.trim().slice(0, 40).replace(/\s+/g, '-').replace(/[^a-zA-Z0-9\-]/g, '') : '';
  return 'tailored-resume' + (snippet ? '-' + snippet : '');
}

/**
 * @param {string} md - markdown body
 * @param {{ skipSuccessToast?: boolean }} opts
 * @returns {Promise<void>}
 */
function downloadTailoredResumeMarkdown(md, opts) {
  opts = opts || {};
  md = String(md || '').trim();
  if (!md) {
    return Promise.reject(new Error('No tailored resume to download.'));
  }
  var filename = tailoredDocxBasename();
  return fetch('/api/resume/tailor/download', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ markdown: md, filename: filename })
  })
    .then(function (res) {
      if (!res.ok) {
        return res.json().then(function (j) { throw new Error(j.error || 'Download failed'); });
      }
      return res.blob().then(function (blob) {
        var disposition = res.headers.get('Content-Disposition') || '';
        var m = /filename="([^"]+)"/.exec(disposition);
        return { blob: blob, fname: m ? m[1] : filename + '.docx' };
      });
    })
    .then(function (o) {
      var a = document.createElement('a');
      a.href = URL.createObjectURL(o.blob);
      a.download = o.fname;
      a.rel = 'noopener';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(a.href);
      if (!opts.skipSuccessToast && typeof showToast === 'function') {
        showToast('Word document downloaded.', 'success');
      }
    });
}

function downloadTailoredResume() {
  var resultTa = document.getElementById('tailorResultMd');
  var md = resultTa ? resultTa.value.trim() : '';
  downloadTailoredResumeMarkdown(md, {})
    .catch(function (e) {
      if (typeof showToast === 'function') showToast(e.message || 'Download failed', 'error');
    });
}
</script>
