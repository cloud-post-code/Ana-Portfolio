<%- include('layout-top', { adminTitle: 'Dashboard' }) %>

<section class="admin__section admin__section--jobs" id="job-crm">
  <div class="admin__section-header">
    <div>
      <h2>Job CRM</h2>
      <p class="admin__section-lead">Roles you are tracking (<%= (jobsCrm || []).length %> listings<% if (typeof starredJobCount !== 'undefined' && starredJobCount) { %>, <strong><%= starredJobCount %> starred</strong><% } %>)</p>
    </div>
  </div>

  <% if (typeof jobSearchProfile !== 'undefined' && jobSearchProfile) { %>
  <div class="admin__crm-profile">
    <h3 class="admin__crm-profile__title"><%= jobSearchProfile.headline || 'What you are looking for' %></h3>
    <% if (jobSearchProfile.summary) { %>
    <p class="admin__crm-profile__summary"><%= jobSearchProfile.summary %></p>
    <% } %>
    <div class="admin__crm-profile__grid">
      <% if (jobSearchProfile.keyDetails && jobSearchProfile.keyDetails.length) { %>
      <div class="admin__crm-profile__block">
        <h4 class="admin__crm-profile__label">Key details</h4>
        <ul class="admin__crm-profile__list">
          <% jobSearchProfile.keyDetails.forEach(function (line) { %>
          <li><%= line %></li>
          <% }); %>
        </ul>
      </div>
      <% } %>
      <% if (jobSearchProfile.targetSkillsToUse && jobSearchProfile.targetSkillsToUse.length) { %>
      <div class="admin__crm-profile__block">
        <h4 class="admin__crm-profile__label">Skills you want to use next</h4>
        <ul class="admin__crm-profile__list admin__crm-profile__list--tags">
          <% jobSearchProfile.targetSkillsToUse.forEach(function (s) { %>
          <li><span class="admin__tag admin__tag--emph"><%= s %></span></li>
          <% }); %>
        </ul>
      </div>
      <% } %>
      <% if (jobSearchProfile.locationsPreferred && jobSearchProfile.locationsPreferred.length) { %>
      <div class="admin__crm-profile__block">
        <h4 class="admin__crm-profile__label">Locations</h4>
        <p class="admin__crm-profile__inline"><%= jobSearchProfile.locationsPreferred.join(' · ') %></p>
      </div>
      <% } %>
      <% if (jobSearchProfile.roleTypesPreferred && jobSearchProfile.roleTypesPreferred.length) { %>
      <div class="admin__crm-profile__block">
        <h4 class="admin__crm-profile__label">Role types</h4>
        <p class="admin__crm-profile__inline"><%= jobSearchProfile.roleTypesPreferred.join(' · ') %></p>
      </div>
      <% } %>
    </div>
    <p class="admin__crm-profile__file-hint">Edit <code>data/job-search-profile.json</code> to update this section. The <code>applicant</code> block (name, email, phone, city) is used for cover letter downloads.</p>
  </div>
  <% } %>

  <% if ((crmJobRows || []).length) { %>
  <div class="admin__jobs-toolbar admin__jobs-toolbar--filters">
    <div class="admin__jobs-filters">
      <label class="admin__jobs-filter-label" for="job-crm-filter-pri">Priority</label>
      <select id="job-crm-filter-pri" class="admin__jobs-filter-select" aria-label="Filter by priority">
        <option value="all">All priorities</option>
        <option value="High">High</option>
        <option value="Medium">Medium</option>
        <option value="Low">Low</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-st">Status</label>
      <select id="job-crm-filter-st" class="admin__jobs-filter-select" aria-label="Filter by status">
        <option value="all">All statuses</option>
        <% (crmStatusOptions || []).forEach(function (s) { %>
        <option value="<%= s %>"><%= s %></option>
        <% }); %>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-star">Saved</label>
      <select id="job-crm-filter-star" class="admin__jobs-filter-select" aria-label="Filter starred">
        <option value="all">All rows</option>
        <option value="starred">Starred only</option>
        <option value="unstarred">Not starred</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-region">Region</label>
      <select id="job-crm-filter-region" class="admin__jobs-filter-select" aria-label="Filter by region">
        <option value="all">All regions</option>
        <option value="boston">Boston area / MA</option>
        <option value="nyc">New York</option>
        <option value="ri">Rhode Island</option>
        <option value="remote">Remote / national</option>
        <option value="other">Other</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-track">Job type</label>
      <select id="job-crm-filter-track" class="admin__jobs-filter-select" aria-label="Filter by job type track">
        <option value="all">All types</option>
        <% (crmTrackOptions || []).forEach(function (t) { %>
        <option value="<%= t.id %>"><%= t.label %></option>
        <% }); %>
        <option value="unclassified">Unclassified</option>
      </select>
    </div>
    <label class="admin__jobs-search-label" for="job-crm-search">Search</label>
    <input
      type="search"
      id="job-crm-search"
      class="admin__jobs-search-input"
      placeholder="Company, role, location, status, tags, skills…"
      autocomplete="off"
      aria-describedby="job-crm-search-hint"
    />
    <span id="job-crm-search-count" class="admin__jobs-search-count" aria-live="polite"></span>
    <p id="job-crm-search-hint" class="admin__jobs-search-hint">Filters combine with search. Words in search must all match.</p>
  </div>
  <div class="admin__jobs-wrap">
    <table class="admin__jobs-table">
      <thead>
        <tr>
          <th scope="col" class="admin__jobs-th-star" title="Star">★</th>
          <th scope="col">#</th>
          <th scope="col">Company</th>
          <th scope="col">Role</th>
          <th scope="col">Location</th>
          <th scope="col">Status</th>
          <th scope="col">Priority</th>
          <th scope="col">Tags</th>
          <th scope="col">Role skills</th>
          <th scope="col">Listing</th>
          <th scope="col">Cover letter</th>
          <th scope="col" class="admin__jobs-th-hult">Hult alumni</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody id="job-crm-tbody">
        <% (crmJobRows || []).forEach(function (row, idx) { var job = row.job; %>
        <% var _crmSt = (job.st != null && String(job.st).trim() !== '') ? String(job.st).trim() : 'To Apply'; %>
        <% var _crmKnown = (typeof crmStatusOptions !== 'undefined' && crmStatusOptions.indexOf(_crmSt) !== -1); %>
        <% var _crmPri = (job.pri != null && String(job.pri).trim() !== '') ? String(job.pri).trim() : 'Medium'; %>
        <% var _crmPriOpts = ['High', 'Medium', 'Low']; %>
        <% var _crmPriKnown = _crmPriOpts.indexOf(_crmPri) !== -1; %>
        <% var _crmPriClass = _crmPriKnown ? _crmPri.toLowerCase() : 'other'; %>
        <% var _searchParts = [job.id, job.co, job.role, job.loc, _crmSt, job.pri, (job.tags || []).join(' '), (job.skills || []).join(' '), job.notes || '', job.url || '']; %>
        <% var _searchBlob = _searchParts.filter(function (p) { return p != null && String(p).length; }).map(function (p) { return String(p); }).join(' '); %>
        <tr class="<%= job.starred ? 'admin__jobs-row--starred' : '' %>"
          data-job-crm-search="<%= encodeURIComponent(_searchBlob) %>"
          data-pri="<%= _crmPri %>"
          data-st="<%= _crmSt %>"
          data-starred="<%= job.starred ? '1' : '0' %>"
          data-region="<%= row.region %>"
          data-tracks="<%= (row.tracks || []).join(' ') %>"
        >
          <td class="admin__jobs-star-cell">
            <button type="button"
              class="admin__job-star<%= job.starred ? ' admin__job-star--on' : '' %>"
              data-id="<%= job.id %>"
              data-starred="<%= job.starred ? '1' : '' %>"
              onclick="toggleJobStar(this)"
              aria-label="<%= job.starred ? 'Remove star' : 'Star job' %>"
              title="<%= job.starred ? 'Unstar' : 'Star' %>"><%= job.starred ? '★' : '☆' %></button>
          </td>
          <td class="admin__jobs-num"><%= idx + 1 %></td>
          <td class="admin__jobs-co"><%= job.co %></td>
          <td>
            <div class="admin__jobs-role"><%= job.role %></div>
            <% if (job.notes) { %>
            <p class="admin__jobs-notes"><%= job.notes %></p>
            <% } %>
          </td>
          <td><%= job.loc %></td>
          <td class="admin__jobs-status-cell">
            <select
              class="admin__job-status"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_crmSt) %>"
              aria-label="Status for <%= job.co %>"
              onchange="updateCrmJobStatus(this)"
            >
              <% if (!_crmKnown) { %>
              <option value="<%= _crmSt %>" selected><%= _crmSt %></option>
              <% } %>
              <% (crmStatusOptions || ['To Apply']).forEach(function(s) { %>
              <option value="<%= s %>"<%= _crmSt === s ? ' selected' : '' %>><%= s %></option>
              <% }); %>
            </select>
          </td>
          <td class="admin__jobs-pri-cell">
            <select
              class="admin__job-priority admin__job-priority--<%= _crmPriClass %>"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_crmPri) %>"
              aria-label="Priority for <%= job.co %>"
              onchange="updateCrmJobPriority(this)"
            >
              <% if (!_crmPriKnown) { %>
              <option value="<%= _crmPri %>" selected><%= _crmPri %></option>
              <% } %>
              <% _crmPriOpts.forEach(function (p) { %>
              <option value="<%= p %>"<%= _crmPri === p ? ' selected' : '' %>><%= p %></option>
              <% }); %>
            </select>
          </td>
          <td>
            <div class="admin__jobs-tags">
              <% (job.tags || []).forEach(function(tag) { %>
              <span class="admin__tag"><%= tag %></span>
              <% }); %>
            </div>
          </td>
          <td class="admin__jobs-skills-cell">
            <div class="admin__jobs-skills">
              <% if ((job.skills || []).length) { %>
              <% (job.skills || []).forEach(function (sk) { %>
              <span class="admin__tag admin__tag--skill"><%= sk %></span>
              <% }); %>
              <% } else { %>
              <span class="admin__text-muted admin__jobs-skills--empty">—</span>
              <% } %>
            </div>
            <button type="button" class="admin__btn admin__btn--tiny admin__btn--outline" onclick="editJobCrmSkills('<%= job.id %>')">Edit skills</button>
          </td>
          <td>
            <% if (job.url) { %>
            <a href="<%= job.url %>" class="admin__jobs-link" target="_blank" rel="noopener noreferrer">Open</a>
            <% } else { %>
            <span class="admin__text-muted">—</span>
            <% } %>
          </td>
          <td class="admin__jobs-cover-cell">
            <button type="button" class="admin__btn admin__btn--small admin__btn--outline" onclick="downloadJobCoverLetter('<%= job.id %>')" title="Generate and download a .txt cover letter">Download letter</button>
          </td>
          <td class="admin__jobs-hult-cell">
            <% var _hultCo = String(job.co || '').trim().replace(/["<>]+/g, ' '); %>
            <% var _hultQ = _hultCo
              ? 'site:linkedin.com/in "Hult International Business School" ' + _hultCo
              : 'site:linkedin.com/in "Hult International Business School" alumni'; %>
            <% var _hultUrl = 'https://www.google.com/search?q=' + encodeURIComponent(_hultQ); %>
            <a href="<%= _hultUrl %>"
              class="admin__btn admin__btn--small admin__btn--outline"
              target="_blank"
              rel="noopener noreferrer"
              title="Google search for LinkedIn profiles that mention Hult International Business School and this company (results vary; you may need to sign in to LinkedIn to view some profiles)."
            >Find alumni</a>
          </td>
          <td class="admin__jobs-actions">
            <button type="button" class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteJobCrm('<%= job.id %>')">Remove</button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <p class="admin__empty-hint">Add <code>data/jobs-crm.json</code> to show your job list.</p>
  <% } %>
</section>

<section class="admin__section">
  <div class="admin__section-header">
    <h2>Work Experience</h2>
    <a href="/admin/experiences/new" class="admin__btn admin__btn--primary">+ Add Experience</a>
  </div>
  <div class="admin__card-grid">
    <% experiences.forEach(function(exp) { %>
    <div class="admin__card">
      <div class="admin__card-header">
        <img src="/<%= exp.logo %>" alt="<%= exp.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
        <div>
          <h3 class="admin__card-title"><%= exp.title %></h3>
          <p class="admin__card-sub"><%= exp.role || exp.type || 'Experience' %></p>
        </div>
      </div>
      <p class="admin__card-desc"><%= exp.description.slice(0, 120) %><%= exp.description.length > 120 ? '...' : '' %></p>
      <div class="admin__card-meta">
        <span><%= (exp.deliverables || []).length %> sub-group(s)</span>
        <span><%= (exp.skills || []).length %> skill(s)</span>
      </div>
      <div class="admin__card-actions">
        <a href="/admin/experiences/<%= exp.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
        <a href="/experience/<%= exp.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
        <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('experiences', '<%= exp.id %>')">Delete</button>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<section class="admin__section">
  <div class="admin__section-header">
    <h2>Projects</h2>
    <a href="/admin/projects/new" class="admin__btn admin__btn--primary">+ Add Project</a>
  </div>
  <div class="admin__card-grid">
    <% projects.forEach(function(proj) { %>
    <div class="admin__card<%= proj.hidden ? ' admin__card--hidden' : '' %>">
      <div class="admin__card-header">
        <img src="/<%= proj.logo %>" alt="<%= proj.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
        <div>
          <h3 class="admin__card-title"><%= proj.title %></h3>
          <p class="admin__card-sub"><%= proj.sectionLabel %><%= proj.hidden ? ' (Hidden)' : '' %></p>
        </div>
      </div>
      <p class="admin__card-desc"><%= proj.description.slice(0, 120) %><%= proj.description.length > 120 ? '...' : '' %></p>
      <div class="admin__card-meta">
        <span><%= (proj.deliverables || []).length %> sub-group(s)</span>
        <span><%= (proj.skills || []).length %> skill(s)</span>
      </div>
      <div class="admin__card-actions">
        <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
        <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
        <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<%- include('layout-bottom') %>
