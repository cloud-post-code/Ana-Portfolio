<%- include('layout-top', { adminTitle: 'Dashboard' }) %>

<section class="admin__section admin__section--jobs" id="job-crm">
  <div class="admin__section-header">
    <div>
      <h2>Job CRM</h2>
      <p class="admin__section-lead">Roles you are tracking (<%= (jobsCrm || []).length %> listings<% if (typeof starredJobCount !== 'undefined' && starredJobCount) { %>, <strong><%= starredJobCount %> starred</strong><% } %>)</p>
    </div>
    <div class="admin__section-header__actions">
      <% var _crmCount = (crmJobRows || []).length; %>
      <button type="button" class="admin__btn admin__btn--outline" title="Reconciles every Job CRM field with Tavily + listing page (optional) and AI. Set ANTHROPIC_API_KEY or OPENAI_API_KEY on the server." onclick="enhanceAllCollection('jobs-crm')"<%= _crmCount ? '' : ' disabled' %>>Enhance all</button>
      <button type="button" class="admin__btn admin__btn--outline admin__btn--danger" title="Delete every job in the CRM" onclick="deleteAllJobsCrm()"<%= _crmCount ? '' : ' disabled' %>>Remove all</button>
    </div>
  </div>

  <div class="admin__job-hunter" id="job-hunter-panel">
    <h3 class="admin__job-hunter__title">Job Hunter <span class="admin__text-muted">(Claude skill)</span></h3>
    <p class="admin__job-hunter__lead">Search the web (optional Tavily, URLs deduplicated) + Claude using the bundled <code>skills/job-hunter</code> skill. Your current <strong>Job CRM</strong> rows are sent so the model should not suggest the same role twice. <strong>Each new lead is merged into <code>data/jobs-crm.json</code></strong> with full CRM fields (company, role, location, notes, tags, status, priority, listing URL when available, YoE, deadline). Deduped by URL and by company+role+location. Set <code>ANTHROPIC_API_KEY</code> on the server.</p>
    <div class="admin__job-hunter__row">
      <div class="admin__job-hunter__field admin__job-hunter__field--grow">
        <label class="admin__job-hunter__label" for="job-hunter-query">Search</label>
        <input
          type="search"
          id="job-hunter-query"
          class="admin__job-hunter__search"
          placeholder="Keywords, location, site:linkedin.com/jobs…"
          autocomplete="off"
          aria-describedby="job-hunter-hint"
        />
      </div>
      <div class="admin__job-hunter__field admin__job-hunter__field--count">
        <label class="admin__job-hunter__label" for="job-hunter-count"># Jobs</label>
        <input
          type="number"
          id="job-hunter-count"
          class="admin__job-hunter__search admin__job-hunter__count"
          min="1"
          max="25"
          step="1"
          value="8"
          inputmode="numeric"
          aria-describedby="job-hunter-hint"
          title="How many job leads to aim for in the Open Roles table (1–25)"
        />
      </div>
      <button type="button" class="admin__btn admin__btn--primary" id="job-hunter-run" onclick="runJobHunterSkillSearch()">Find jobs</button>
    </div>
    <label class="admin__job-hunter__label" for="job-hunter-criteria">More criteria <span class="admin__text-muted">(optional)</span></label>
    <textarea
      id="job-hunter-criteria"
      class="admin__job-hunter__textarea"
      rows="4"
      placeholder="Industries, role titles, exclusions (-intern), seniority, remote/hybrid…"
      aria-describedby="job-hunter-hint"
    ></textarea>
    <p id="job-hunter-hint" class="admin__job-hunter__hint">At least one of Search or More criteria must be filled. Results appear below (verify links before applying).</p>
    <div id="job-hunter-status" class="admin__job-hunter__status" hidden></div>
    <div id="job-hunter-output" class="admin__job-hunter__output" hidden></div>
  </div>

  <% if ((crmJobRows || []).length) { %>
  <div class="admin__jobs-toolbar admin__jobs-toolbar--filters">
    <div class="admin__jobs-filters">
      <label class="admin__jobs-filter-label" for="job-crm-filter-pri">Priority</label>
      <select id="job-crm-filter-pri" class="admin__jobs-filter-select" aria-label="Filter by priority">
        <option value="all">All priorities</option>
        <option value="High">High</option>
        <option value="Medium">Medium</option>
        <option value="Low">Low</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-st">Status</label>
      <select id="job-crm-filter-st" class="admin__jobs-filter-select" aria-label="Filter by status">
        <option value="all">All statuses</option>
        <% (crmStatusOptions || []).forEach(function (s) { %>
        <option value="<%= s %>"><%= s %></option>
        <% }); %>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-star">Saved</label>
      <select id="job-crm-filter-star" class="admin__jobs-filter-select" aria-label="Filter starred">
        <option value="all">All rows</option>
        <option value="starred">Starred only</option>
        <option value="unstarred">Not starred</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-region">Region</label>
      <select id="job-crm-filter-region" class="admin__jobs-filter-select" aria-label="Filter by region">
        <option value="all">All regions</option>
        <option value="boston">Boston area / MA</option>
        <option value="nyc">New York</option>
        <option value="ri">Rhode Island</option>
        <option value="remote">Remote / national</option>
        <option value="other">Other</option>
      </select>
      <label class="admin__jobs-filter-label" for="job-crm-filter-track">Job type</label>
      <select id="job-crm-filter-track" class="admin__jobs-filter-select" aria-label="Filter by job type track">
        <option value="all">All types</option>
        <% (crmTrackOptions || []).forEach(function (t) { %>
        <option value="<%= t.id %>"><%= t.label %></option>
        <% }); %>
        <option value="unclassified">Unclassified</option>
      </select>
    </div>
    <label class="admin__jobs-search-label" for="job-crm-search">Search</label>
    <input
      type="search"
      id="job-crm-search"
      class="admin__jobs-search-input"
      placeholder="Company, role, years exp, details, location, status, tags…"
      autocomplete="off"
      aria-describedby="job-crm-search-hint"
    />
    <span id="job-crm-search-count" class="admin__jobs-search-count" aria-live="polite"></span>
    <p id="job-crm-search-hint" class="admin__jobs-search-hint">Filters combine with search. Words in search must all match.</p>
  </div>
  <div class="admin__jobs-wrap">
    <table class="admin__jobs-table">
      <thead>
        <tr>
          <th scope="col" class="admin__jobs-th-star" title="Star">★</th>
          <th scope="col">#</th>
          <th scope="col">Company</th>
          <th scope="col">Role</th>
          <th scope="col" title="Years of experience required">Yrs exp</th>
          <th scope="col">Job details</th>
          <th scope="col">Location</th>
          <th scope="col">Deadline</th>
          <th scope="col">Status</th>
          <th scope="col">Priority</th>
          <th scope="col">Tags</th>
          <th scope="col">Listing</th>
          <th scope="col">Cover letter</th>
          <th scope="col" class="admin__jobs-th-hult">Hult alumni</th>
          <th scope="col">Actions</th>
        </tr>
      </thead>
      <tbody id="job-crm-tbody">
        <% (crmJobRows || []).forEach(function (row, idx) { var job = row.job; %>
        <% var _crmSt = (job.st != null && String(job.st).trim() !== '') ? String(job.st).trim() : 'To Apply'; %>
        <% var _crmKnown = (typeof crmStatusOptions !== 'undefined' && crmStatusOptions.indexOf(_crmSt) !== -1); %>
        <% var _crmPri = (job.pri != null && String(job.pri).trim() !== '') ? String(job.pri).trim() : 'Medium'; %>
        <% var _crmPriOpts = ['High', 'Medium', 'Low']; %>
        <% var _crmPriKnown = _crmPriOpts.indexOf(_crmPri) !== -1; %>
        <% var _crmPriClass = _crmPriKnown ? _crmPri.toLowerCase() : 'other'; %>
        <% var _searchParts = [job.id, job.co, job.role, job.yoe || '', job.loc, job.deadline || '', _crmSt, job.pri, (job.tags || []).join(' '), job.notes || '', job.url || '']; %>
        <% var _searchBlob = _searchParts.filter(function (p) { return p != null && String(p).length; }).map(function (p) { return String(p); }).join(' '); %>
        <tr class="<%= job.starred ? 'admin__jobs-row--starred' : '' %>"
          data-job-crm-search="<%= encodeURIComponent(_searchBlob) %>"
          data-pri="<%= _crmPri %>"
          data-st="<%= _crmSt %>"
          data-starred="<%= job.starred ? '1' : '0' %>"
          data-region="<%= row.region %>"
          data-tracks="<%= (row.tracks || []).join(' ') %>"
        >
          <td class="admin__jobs-star-cell">
            <button type="button"
              class="admin__job-star<%= job.starred ? ' admin__job-star--on' : '' %>"
              data-id="<%= job.id %>"
              data-starred="<%= job.starred ? '1' : '' %>"
              onclick="toggleJobStar(this)"
              aria-label="<%= job.starred ? 'Remove star' : 'Star job' %>"
              title="<%= job.starred ? 'Unstar' : 'Star' %>"><%= job.starred ? '★' : '☆' %></button>
          </td>
          <td class="admin__jobs-num"><%= idx + 1 %></td>
          <td class="admin__jobs-co"><%= job.co %></td>
          <td>
            <div class="admin__jobs-role"><%= job.role %></div>
          </td>
          <td class="admin__jobs-yoe-cell">
            <% var _yoeRaw = job.yoe != null ? String(job.yoe) : ''; %>
            <input
              type="text"
              class="admin__job-yoe"
              value="<%= _yoeRaw.replace(/&/g, '&amp;').replace(/"/g, '&quot;') %>"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_yoeRaw) %>"
              placeholder="e.g. 0–2, 3–5"
              aria-label="Years of experience required for <%= job.co %>"
              onchange="updateCrmJobYoe(this)"
            />
          </td>
          <td class="admin__jobs-details-cell">
            <% var _notesRaw = job.notes != null ? String(job.notes) : ''; %>
            <textarea
              class="admin__job-details"
              rows="3"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_notesRaw) %>"
              placeholder="Requirements, salary, team notes…"
              aria-label="Job details for <%= job.co %>"
              onblur="updateCrmJobNotes(this)"
            ><%= _notesRaw.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;') %></textarea>
          </td>
          <td><%= job.loc %></td>
          <td class="admin__jobs-deadline-cell">
            <% var _dlRaw = job.deadline != null ? String(job.deadline) : ''; %>
            <input
              type="text"
              class="admin__job-deadline"
              value="<%= _dlRaw.replace(/&/g, '&amp;').replace(/"/g, '&quot;') %>"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_dlRaw) %>"
              placeholder="e.g. 2025-05-01, Rolling"
              aria-label="Application deadline for <%= job.co %>"
              onchange="updateCrmJobDeadline(this)"
            />
          </td>
          <td class="admin__jobs-status-cell">
            <select
              class="admin__job-status"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_crmSt) %>"
              aria-label="Status for <%= job.co %>"
              onchange="updateCrmJobStatus(this)"
            >
              <% if (!_crmKnown) { %>
              <option value="<%= _crmSt %>" selected><%= _crmSt %></option>
              <% } %>
              <% (crmStatusOptions || ['To Apply']).forEach(function(s) { %>
              <option value="<%= s %>"<%= _crmSt === s ? ' selected' : '' %>><%= s %></option>
              <% }); %>
            </select>
          </td>
          <td class="admin__jobs-pri-cell">
            <select
              class="admin__job-priority admin__job-priority--<%= _crmPriClass %>"
              data-id="<%= job.id %>"
              data-prev="<%= encodeURIComponent(_crmPri) %>"
              aria-label="Priority for <%= job.co %>"
              onchange="updateCrmJobPriority(this)"
            >
              <% if (!_crmPriKnown) { %>
              <option value="<%= _crmPri %>" selected><%= _crmPri %></option>
              <% } %>
              <% _crmPriOpts.forEach(function (p) { %>
              <option value="<%= p %>"<%= _crmPri === p ? ' selected' : '' %>><%= p %></option>
              <% }); %>
            </select>
          </td>
          <td>
            <div class="admin__jobs-tags">
              <% (job.tags || []).forEach(function(tag) { %>
              <span class="admin__tag"><%= tag %></span>
              <% }); %>
            </div>
          </td>
          <td class="admin__jobs-listing-cell">
            <% if (job.url) { %>
            <a href="<%= job.url %>" class="admin__btn admin__btn--small admin__btn--outline admin__btn--icon" target="_blank" rel="noopener noreferrer" title="Open job listing" aria-label="Open job listing">
              <svg class="admin__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            </a>
            <% } else { %>
            <span class="admin__text-muted">—</span>
            <% } %>
          </td>
          <td class="admin__jobs-cover-cell">
            <button type="button" class="admin__btn admin__btn--small admin__btn--outline admin__btn--icon" onclick="downloadJobCoverLetter('<%= job.id %>')" title="Download cover letter (.docx)" aria-label="Download cover letter">
              <svg class="admin__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </button>
          </td>
          <td class="admin__jobs-hult-cell">
            <% var _hultCo = String(job.co || '').trim().replace(/["<>]+/g, ' '); %>
            <% var _hultUrl = _hultCo
              ? 'https://www.linkedin.com/search/results/people/?keywords=' + encodeURIComponent('Hult International Business School ' + _hultCo)
              : 'https://www.linkedin.com/school/hult-international-business-school/people/'; %>
            <a href="<%= _hultUrl %>"
              class="admin__btn admin__btn--small admin__btn--outline admin__btn--icon"
              target="_blank"
              rel="noopener noreferrer"
              title="Search LinkedIn for Hult alumni at this company"
              aria-label="Search LinkedIn for Hult alumni"
            >
              <svg class="admin__icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </a>
          </td>
          <td class="admin__jobs-actions">
            <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: refresh company, role, location, notes, tags, URL, deadline, YoE from listing/context" onclick="enhanceOne('jobs-crm','<%= job.id %>')">Enhance</button>
            <button type="button" class="admin__btn admin__btn--small admin__btn--outline admin__btn--remove" onclick="deleteJobCrm('<%= job.id %>')" title="Remove from CRM">Remove</button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <p class="admin__empty-hint">Add <code>data/jobs-crm.json</code> to show your job list.</p>
  <% } %>
</section>

<section class="admin__section">
  <div class="admin__section-header">
    <h2>Work Experience</h2>
    <div class="admin__section-header__actions">
      <button type="button" class="admin__btn admin__btn--outline" title="AI + optional web search: fill empty experience fields" onclick="enhanceAllCollection('experiences')">Enhance all</button>
      <a href="/admin/experiences/new" class="admin__btn admin__btn--primary">+ Add Experience</a>
    </div>
  </div>
  <div class="admin__card-grid">
    <% experiences.forEach(function(exp) { %>
    <div class="admin__card">
      <div class="admin__card-header">
        <img src="/<%= exp.logo %>" alt="<%= exp.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
        <div>
          <h3 class="admin__card-title"><%= exp.title %></h3>
          <p class="admin__card-sub"><%= exp.role || exp.type || 'Experience' %></p>
        </div>
      </div>
      <p class="admin__card-desc"><%= exp.description.slice(0, 120) %><%= exp.description.length > 120 ? '...' : '' %></p>
      <div class="admin__card-meta">
        <span><%= (exp.deliverables || []).length %> sub-group(s)</span>
        <span><%= (exp.skills || []).length %> skill(s)</span>
      </div>
      <div class="admin__card-actions">
        <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: fill missing text/skills" onclick="enhanceOne('experiences','<%= exp.id %>')">Enhance</button>
        <a href="/admin/experiences/<%= exp.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
        <a href="/experience/<%= exp.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
        <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('experiences', '<%= exp.id %>')">Delete</button>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<section class="admin__section">
  <div class="admin__section-header">
    <h2>Projects</h2>
    <div class="admin__section-header__actions">
      <button type="button" class="admin__btn admin__btn--outline" title="AI + optional web search: fill empty project fields" onclick="enhanceAllCollection('projects')">Enhance all</button>
      <a href="/admin/projects/new" class="admin__btn admin__btn--primary">+ Add Project</a>
    </div>
  </div>
  <div class="admin__card-grid">
    <% projects.forEach(function(proj) { %>
    <div class="admin__card<%= proj.hidden ? ' admin__card--hidden' : '' %>">
      <div class="admin__card-header">
        <img src="/<%= proj.logo %>" alt="<%= proj.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
        <div>
          <h3 class="admin__card-title"><%= proj.title %></h3>
          <p class="admin__card-sub"><%= proj.sectionLabel %><%= proj.hidden ? ' (Hidden)' : '' %></p>
        </div>
      </div>
      <p class="admin__card-desc"><%= proj.description.slice(0, 120) %><%= proj.description.length > 120 ? '...' : '' %></p>
      <div class="admin__card-meta">
        <span><%= (proj.deliverables || []).length %> sub-group(s)</span>
        <span><%= (proj.skills || []).length %> skill(s)</span>
      </div>
      <div class="admin__card-actions">
        <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: fill missing text/skills" onclick="enhanceOne('projects','<%= proj.id %>')">Enhance</button>
        <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
        <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
        <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
      </div>
    </div>
    <% }); %>
  </div>
</section>

<%- include('layout-bottom') %>
