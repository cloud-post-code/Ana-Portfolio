<%- include('layout-top', { adminTitle: 'Dashboard' }) %>

<% var spotExp = experiences.slice(0, 3); %>
<% var spotClient = clientProjects.slice(0, 3); %>
<% var spotPersonal = personalProjects.slice(0, 3); %>
<% var nExp = experiences.length; %>
<% var nClient = clientProjects.length; %>
<% var nPersonal = personalProjects.length; %>
<% var nProj = projects.length; %>

<div class="admin-dash">
  <div class="admin-dash__below">
    <div class="admin-dash__hero-cta">
      <a href="/admin/experiences/new" class="admin__btn admin__btn--primary">New experience</a>
      <a href="/admin/projects/new" class="admin__btn admin__btn--outline">New client project</a>
      <a href="/admin/projects/new?type=personal" class="admin__btn admin__btn--outline">New personal project</a>
      <a href="/" class="admin__btn admin__btn--outline" target="_blank" rel="noopener">Live site</a>
    </div>

    <section class="admin-dash__spotlight admin-dash__spotlight--anchor" id="admin-work-experience">
      <div class="admin-dash__spotlight-head">
        <h3 class="admin-dash__spotlight-title">Work Experiences</h3>
        <a href="/admin/experiences/new" class="admin__btn admin__btn--primary">New Work Experience</a>
      </div>
      <div class="admin-dash__spotlight-below-title">
        <p class="admin-dash__spotlight-sub">Spotlight — up to three featured. Everything else stays in the full library drawer below.</p>
        <div class="admin-dash__spotlight-actions">
          <button type="button" class="admin__btn admin__btn--outline" title="AI + optional web search" onclick="enhanceAllCollection('experiences')">Enhance all</button>
        </div>
      </div>

      <div class="admin-dash__presentation-card admin__card admin-dash__hero-video-card">
        <h4 class="admin-dash__presentation-title">Hero background video</h4>
        <p class="admin-dash__presentation-lead admin__text-muted">
          Full-screen loop behind the homepage name block. MP4, WebM, or MOV · max 50 MB. Without a video, the hero uses the default light background.<% if (typeof databaseEnabled !== 'undefined' && databaseEnabled) { %> Video is stored in PostgreSQL and persists across deploys.<% } %>
        </p>
        <% var heroHasVideo = heroVideo && heroVideo.fileExists; %>
        <% if (heroHasVideo) { %>
        <p class="admin__resume-meta" style="margin-bottom:0.75rem;">
          <strong>Current:</strong> <%= heroVideo.originalFilename || heroVideo.serveUrl || 'Hero video' %>
          <% if (heroVideo.updatedAt) { %>
          <span class="admin__text-muted"> · Uploaded <%= new Date(heroVideo.updatedAt).toLocaleString() %></span>
          <% } %>
        </p>
        <div class="admin__resume-actions" style="margin-bottom:1rem;">
          <button type="button" class="admin__btn admin__btn--danger" onclick="deleteHeroVideo()">Remove video</button>
          <a href="/" class="admin__btn admin__btn--outline" target="_blank" rel="noopener">Preview homepage</a>
        </div>
        <% } else { %>
        <p class="admin__text-muted" style="margin-bottom:1rem;font-size:0.88rem;">No hero video yet — upload one below.</p>
        <% } %>
        <form class="admin__resume-form" id="heroVideoUploadForm" novalidate>
          <p class="admin__resume-upload-meta">MP4, WebM, or MOV · max 50 MB</p>
          <div class="admin__resume-upload-field">
            <input
              type="file"
              id="heroVideoFile"
              name="video"
              accept="video/mp4,video/webm,video/quicktime,.mp4,.webm,.mov"
              class="admin__resume-file-input-native"
              tabindex="-1"
              aria-label="Choose hero background video"
            />
            <label for="heroVideoFile" class="admin__resume-dropzone" id="heroVideoDropzone" tabindex="0">
              <span class="admin__visually-hidden">Choose hero background video</span>
              <div class="admin__resume-dropzone__body">
                <p class="admin__resume-dropzone__lead">Drop your video here</p>
                <p class="admin__resume-dropzone__or">or <span class="admin__resume-browse">click to browse</span></p>
                <p class="admin__resume-file-name" id="heroVideoFileName"><span class="admin__resume-file-name__placeholder">No file selected</span></p>
              </div>
            </label>
          </div>
          <div class="admin__resume-upload-actions">
            <button type="submit" class="admin__btn admin__btn--primary" id="heroVideoSubmitBtn" disabled><%= heroHasVideo ? 'Upload & replace' : 'Upload video' %></button>
          </div>
        </form>
      </div>

      <div class="admin-dash__presentation-card admin__card">
        <h4 class="admin-dash__presentation-title">Homepage presentation view</h4>
        <p class="admin-dash__presentation-lead admin__text-muted">
          On the live homepage, show only the large name block and skills strip (hides navigation, footer, and all other sections). Visitors cannot change this from the site—only this admin checkbox does. Stored in this browser only; refresh the homepage after toggling.
        </p>
        <label class="admin-dash__presentation-check">
          <input type="checkbox" id="adminPortfolioFocusToggle" />
          <span>Enable on this device</span>
        </label>
        <p class="admin-dash__presentation-foot admin__text-muted">
          <a href="/" target="_blank" rel="noopener">Open homepage</a>
        </p>
      </div>

      <% if (!spotExp.length) { %>
      <p class="admin__empty-hint">No experiences yet — add your first capsule.</p>
      <% } else { %>
      <div class="admin-dash__spotlight-grid">
        <% spotExp.forEach(function(exp) { %>
        <article class="admin-dash__spot-card">
          <div class="admin-dash__spot-card__shine" aria-hidden="true"></div>
          <div class="admin-dash__spot-card__top">
            <% if (exp.logo) { %>
            <img src="/<%= exp.logo %>" alt="" class="admin-dash__spot-logo" onerror="this.style.display='none'" />
            <% } %>
            <h4 class="admin-dash__spot-name"><%= exp.title %></h4>
          </div>
          <div class="admin-dash__spot-card__below">
            <p class="admin-dash__spot-role"><%= exp.role || exp.type || 'Experience' %></p>
            <p class="admin-dash__spot-blurb"><%= (exp.description || '').slice(0, 100) %><%= (exp.description || '').length > 100 ? '…' : '' %></p>
            <div class="admin-dash__spot-footer">
              <a href="/admin/experiences/<%= exp.id %>/edit" class="admin__btn admin__btn--small admin__btn--primary">Edit</a>
              <a href="/experience/<%= exp.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank" rel="noopener">View</a>
              <button type="button" class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('experiences', '<%= exp.id %>')">Delete</button>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
      <% } %>
    </section>

    <section class="admin-dash__spotlight admin-dash__spotlight--projects admin-dash__spotlight--anchor" id="admin-client-projects">
      <div class="admin-dash__spotlight-head">
        <h3 class="admin-dash__spotlight-title">Client Projects</h3>
        <a href="/admin/projects/new" class="admin__btn admin__btn--primary">New client project</a>
      </div>
      <div class="admin-dash__spotlight-below-title">
        <p class="admin-dash__spotlight-sub">Spotlight — up to three featured. Open the full client project library drawer below for the rest.</p>
        <div class="admin-dash__spotlight-actions">
          <button type="button" class="admin__btn admin__btn--outline" title="AI + optional web search" onclick="enhanceAllCollection('projects')">Enhance all projects</button>
        </div>
      </div>
      <% if (!spotClient.length) { %>
      <p class="admin__empty-hint">No client projects yet — add your first case study.</p>
      <% } else { %>
      <div class="admin-dash__spotlight-grid">
        <% spotClient.forEach(function(proj) { %>
        <article class="admin-dash__spot-card<%= proj.hidden ? ' admin-dash__spot-card--muted' : '' %>">
          <div class="admin-dash__spot-card__shine admin-dash__spot-card__shine--cool" aria-hidden="true"></div>
          <div class="admin-dash__spot-card__top">
            <% if (proj.logo) { %>
            <img src="/<%= proj.logo %>" alt="" class="admin-dash__spot-logo" onerror="this.style.display='none'" />
            <% } %>
            <h4 class="admin-dash__spot-name"><%= proj.title %></h4>
          </div>
          <div class="admin-dash__spot-card__below">
            <p class="admin-dash__spot-role"><%= projectTypeLabel(proj) %><%= proj.hidden ? ' · hidden' : '' %></p>
            <p class="admin-dash__spot-blurb"><%= (proj.description || '').slice(0, 100) %><%= (proj.description || '').length > 100 ? '…' : '' %></p>
            <div class="admin-dash__spot-footer">
              <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small admin__btn--primary">Edit</a>
              <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank" rel="noopener">View</a>
              <button type="button" class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
      <% } %>
    </section>

    <section class="admin-dash__spotlight admin-dash__spotlight--projects admin-dash__spotlight--anchor" id="admin-personal-projects">
      <div class="admin-dash__spotlight-head">
        <h3 class="admin-dash__spotlight-title">Personal Projects</h3>
        <a href="/admin/projects/new?type=personal" class="admin__btn admin__btn--primary">New personal project</a>
      </div>
      <div class="admin-dash__spotlight-below-title">
        <p class="admin-dash__spotlight-sub">Spotlight — up to three featured. Open the full personal project library drawer below for the rest.</p>
      </div>
      <% if (!spotPersonal.length) { %>
      <p class="admin__empty-hint">No personal projects yet — add your first one.</p>
      <% } else { %>
      <div class="admin-dash__spotlight-grid">
        <% spotPersonal.forEach(function(proj) { %>
        <article class="admin-dash__spot-card<%= proj.hidden ? ' admin-dash__spot-card--muted' : '' %>">
          <div class="admin-dash__spot-card__shine admin-dash__spot-card__shine--cool" aria-hidden="true"></div>
          <div class="admin-dash__spot-card__top">
            <% if (proj.logo) { %>
            <img src="/<%= proj.logo %>" alt="" class="admin-dash__spot-logo" onerror="this.style.display='none'" />
            <% } %>
            <h4 class="admin-dash__spot-name"><%= proj.title %></h4>
          </div>
          <div class="admin-dash__spot-card__below">
            <p class="admin-dash__spot-role"><%= projectTypeLabel(proj) %><%= proj.hidden ? ' · hidden' : '' %></p>
            <p class="admin-dash__spot-blurb"><%= (proj.description || '').slice(0, 100) %><%= (proj.description || '').length > 100 ? '…' : '' %></p>
            <div class="admin-dash__spot-footer">
              <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small admin__btn--primary">Edit</a>
              <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank" rel="noopener">View</a>
              <button type="button" class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
            </div>
          </div>
        </article>
        <% }); %>
      </div>
      <% } %>
    </section>

    <details class="admin-dash__drawer">
      <summary class="admin-dash__drawer-summary">Full experience library <span class="admin-dash__drawer-count">(<%= nExp %>)</span></summary>
      <div class="admin-dash__drawer-body">
        <div class="admin__section-header" style="margin-bottom: 1rem;">
          <a href="/admin/experiences/new" class="admin__btn admin__btn--primary">+ Add Experience</a>
        </div>
        <div class="admin__card-grid">
          <% experiences.forEach(function(exp) { %>
          <div class="admin__card">
            <div class="admin__card-header">
              <img src="/<%= exp.logo %>" alt="<%= exp.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
              <div>
                <h3 class="admin__card-title"><%= exp.title %></h3>
              </div>
            </div>
            <div class="admin-dash__library-card-below">
              <p class="admin__card-sub"><%= exp.role || exp.type || 'Experience' %></p>
              <p class="admin__card-desc"><%= (exp.description || '').slice(0, 120) %><%= (exp.description || '').length > 120 ? '...' : '' %></p>
              <div class="admin__card-meta">
                <span><%= (exp.deliverables || []).length %> sub-group(s)</span>
              </div>
              <div class="admin__card-actions">
                <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: fill missing text" onclick="enhanceOne('experiences','<%= exp.id %>')">Enhance</button>
                <a href="/admin/experiences/<%= exp.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
                <a href="/experience/<%= exp.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
                <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('experiences', '<%= exp.id %>')">Delete</button>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </details>

    <details class="admin-dash__drawer">
      <summary class="admin-dash__drawer-summary">Full client project library <span class="admin-dash__drawer-count">(<%= nClient %>)</span></summary>
      <div class="admin-dash__drawer-body">
        <div class="admin__section-header" style="margin-bottom: 1rem;">
          <a href="/admin/projects/new" class="admin__btn admin__btn--primary">+ Add client project</a>
        </div>
        <div class="admin__card-grid">
          <% clientProjects.forEach(function(proj) { %>
          <div class="admin__card<%= proj.hidden ? ' admin__card--hidden' : '' %>">
            <div class="admin__card-header">
              <img src="/<%= proj.logo %>" alt="<%= proj.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
              <div>
                <h3 class="admin__card-title"><%= proj.title %></h3>
              </div>
            </div>
            <div class="admin-dash__library-card-below">
              <p class="admin__card-sub"><%= projectTypeLabel(proj) %><%= proj.hidden ? ' (Hidden)' : '' %></p>
              <p class="admin__card-desc"><%= (proj.description || '').slice(0, 120) %><%= (proj.description || '').length > 120 ? '...' : '' %></p>
              <div class="admin__card-meta">
                <span><%= (proj.deliverables || []).length %> sub-group(s)</span>
              </div>
              <div class="admin__card-actions">
                <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: fill missing text" onclick="enhanceOne('projects','<%= proj.id %>')">Enhance</button>
                <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
                <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
                <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </details>

    <details class="admin-dash__drawer">
      <summary class="admin-dash__drawer-summary">Full personal project library <span class="admin-dash__drawer-count">(<%= nPersonal %>)</span></summary>
      <div class="admin-dash__drawer-body">
        <div class="admin__section-header" style="margin-bottom: 1rem;">
          <a href="/admin/projects/new?type=personal" class="admin__btn admin__btn--primary">+ Add personal project</a>
        </div>
        <div class="admin__card-grid">
          <% personalProjects.forEach(function(proj) { %>
          <div class="admin__card<%= proj.hidden ? ' admin__card--hidden' : '' %>">
            <div class="admin__card-header">
              <img src="/<%= proj.logo %>" alt="<%= proj.title %>" class="admin__card-logo" onerror="this.style.display='none'" />
              <div>
                <h3 class="admin__card-title"><%= proj.title %></h3>
              </div>
            </div>
            <div class="admin-dash__library-card-below">
              <p class="admin__card-sub"><%= projectTypeLabel(proj) %><%= proj.hidden ? ' (Hidden)' : '' %></p>
              <p class="admin__card-desc"><%= (proj.description || '').slice(0, 120) %><%= (proj.description || '').length > 120 ? '...' : '' %></p>
              <div class="admin__card-meta">
                <span><%= (proj.deliverables || []).length %> sub-group(s)</span>
              </div>
              <div class="admin__card-actions">
                <button type="button" class="admin__btn admin__btn--small admin__btn--outline" title="AI + web: fill missing text" onclick="enhanceOne('projects','<%= proj.id %>')">Enhance</button>
                <a href="/admin/projects/<%= proj.id %>/edit" class="admin__btn admin__btn--small">Edit</a>
                <a href="/project/<%= proj.slug %>" class="admin__btn admin__btn--small admin__btn--outline" target="_blank">View</a>
                <button class="admin__btn admin__btn--small admin__btn--danger" onclick="deleteItem('projects', '<%= proj.id %>')">Delete</button>
              </div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </details>
  </div>
</div>

<%- include('layout-bottom') %>
