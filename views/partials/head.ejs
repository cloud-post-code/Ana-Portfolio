<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
<title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Ana Machuca — Humanizing Brands' %></title>
<meta name="description" content="<%= typeof pageDesc !== 'undefined' ? pageDesc : 'Ana Machuca — marketing portfolio for recruiters and hiring managers.' %>" />
<%
  var ogTitle = typeof pageTitle !== 'undefined' ? pageTitle : 'Ana Machuca — Humanizing Brands';
  var ogDesc = typeof pageDesc !== 'undefined' ? pageDesc : 'Take a look around my marketing playground';
  var ogOrigin = typeof siteOrigin !== 'undefined' ? siteOrigin : '';
  var ogPageUrl = typeof pageUrl !== 'undefined' ? pageUrl : ogOrigin + '/';
  var ogImage = ogOrigin + '/assets/og-card.png';
%>
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Ana Machuca" />
<meta property="og:title" content="<%= ogTitle %>" />
<meta property="og:description" content="<%= ogDesc %>" />
<meta property="og:url" content="<%= ogPageUrl %>" />
<meta property="og:image" content="<%= ogImage %>" />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<%= ogTitle %>" />
<meta name="twitter:description" content="<%= ogDesc %>" />
<meta name="twitter:image" content="<%= ogImage %>" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Anton&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="/styles.css" />
