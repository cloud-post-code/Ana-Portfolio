<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <% var visibleProjects = projects.filter(function (p) { return !p.hidden; }); %>
  <% var clientProjects = visibleProjects.filter(function (p) { return p.projectType !== 'personal'; }); %>
  <% var personalProjects = visibleProjects.filter(function (p) { return p.projectType === 'personal'; }); %>
  <%- include('partials/nav') %>

  <!-- Hero -->
  <%
    var hv = (typeof heroVideo !== 'undefined' && heroVideo) ? heroVideo : {};
    var hvDesktop = hv.desktop || {};
    var hvMobile = hv.mobile || {};
    var heroDesktopSrc = (hvDesktop.fileExists && hvDesktop.serveUrl) ? hvDesktop.serveUrl : '';
    var heroMobileSrc = (hvMobile.fileExists && hvMobile.serveUrl) ? hvMobile.serveUrl : '';
    var heroDesktopPlay = heroDesktopSrc || heroMobileSrc;
    var heroMobilePlay = heroMobileSrc || heroDesktopSrc;
    var heroHasVideo = !!(heroDesktopPlay || heroMobilePlay);
    function heroIsHtml(meta) {
      if (!meta) return false;
      var mime = meta.mimeType ? String(meta.mimeType).toLowerCase() : '';
      if (mime === 'text/html' || mime === 'application/xhtml+xml') return true;
      var name = meta.originalFilename ? String(meta.originalFilename).toLowerCase() : '';
      return /\.html?$/.test(name);
    }
    function heroDesktopHtml() {
      if (!heroDesktopPlay) return false;
      if (hvDesktop.fileExists) return heroIsHtml(hvDesktop);
      return heroIsHtml(hvMobile);
    }
    function heroMobileHtml() {
      if (!heroMobilePlay) return false;
      if (hvMobile.fileExists) return heroIsHtml(hvMobile);
      return heroIsHtml(hvDesktop);
    }
  %>
  <section class="hero<%= heroHasVideo ? ' hero--has-video' : '' %>" id="hero">
    <% if (heroHasVideo) { %>
    <div class="hero__video-wrap" aria-hidden="true">
      <% if (heroDesktopPlay) { %>
      <% if (heroDesktopHtml()) { %>
      <iframe class="hero__video hero__video--desktop hero__html" src="<%= heroDesktopPlay %>" title="" tabindex="-1"></iframe>
      <% } else { %>
      <video class="hero__video hero__video--desktop" src="<%= heroDesktopPlay %>" autoplay muted loop playsinline></video>
      <% } %>
      <% } %>
      <% if (heroMobilePlay) { %>
      <% if (heroMobileHtml()) { %>
      <iframe class="hero__video hero__video--mobile hero__html" src="<%= heroMobilePlay %>" title="" tabindex="-1"></iframe>
      <% } else { %>
      <video class="hero__video hero__video--mobile" src="<%= heroMobilePlay %>" autoplay muted loop playsinline></video>
      <% } %>
      <% } %>
    </div>
    <% } %>
    <div class="hero__content">
      <h1 class="hero__title">
        <span class="hero__title-line"><span class="hero__title-inner">Ana</span></span>
        <span class="hero__title-line hero__title-line--accent"><span class="hero__title-inner">Machuca</span></span>
      </h1>
      <p class="hero__tagline reveal-blur">Take a look around my marketing playground</p>
      <div class="hero__actions reveal-scale">
        <a href="#contact" class="btn btn--primary">Contact me</a>
        <a href="#brands" class="btn btn--outline">View</a>
      </div>
    </div>
  </section>

  <!-- Brands strip: work experience -->
  <section class="brands section" id="brands" aria-label="Work experiences — company logos">
    <div class="container brands__focus-main">
      <div class="brands__groups">
        <div class="brands__group reveal-scale">
          <h3 class="brands__group-title">WORK EXPERIENCES</h3>
          <% if (!experiences.length) { %>
          <p class="portfolio-empty">No work experience entries yet — add them from the admin dashboard and they appear here automatically.</p>
          <% } else { %>
          <div class="brands__grid">
            <% experiences.forEach(function(exp) { %>
            <a href="/experience/<%= exp.slug %>" class="brand-tile<%= exp.logoHover ? ' brand-tile--has-hover' : '' %>">
              <span class="brand-tile__logo-wrap">
                <img src="/<%= exp.logo %>" alt="<%= exp.title %>" class="brand-tile__logo brand-tile__logo--default" />
                <% if (exp.logoHover) { %>
                <img src="/<%= exp.logoHover %>" alt="" aria-hidden="true" class="brand-tile__logo brand-tile__logo--hover" />
                <% } %>
              </span>
              <span class="brand-tile__name"><%= exp.title.toUpperCase() %></span>
              <span class="brand-tile__cta">VIEW DETAILS</span>
              <% if (exp.tags && exp.tags.length) { %>
              <span class="brand-tile__tags">
                <% exp.tags.forEach(function(tag) { %>
                <span class="brand-tile__tag"><%= tag %></span>
                <% }); %>
              </span>
              <% } %>
            </a>
            <% }); %>
          </div>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <!-- Client projects -->
  <section class="brands section" id="client-projects" aria-label="Client projects">
    <div class="container brands__focus-main">
      <div class="brands__groups">
        <div class="brands__group reveal-scale">
          <h3 class="brands__group-title">CLIENT PROJECTS</h3>
          <%- include('partials/project-tiles', {
            projects: clientProjects,
            emptyMessage: 'No client projects to show yet. Add them from the admin dashboard and mark them as Client project.'
          }) %>
        </div>
      </div>
    </div>
  </section>

  <!-- Personal projects -->
  <section class="brands section" id="personal-projects" aria-label="Personal projects">
    <div class="container brands__focus-main">
      <div class="brands__groups">
        <div class="brands__group reveal-scale">
          <h3 class="brands__group-title">PERSONAL PROJECTS</h3>
          <%- include('partials/project-tiles', {
            projects: personalProjects,
            emptyMessage: 'No personal projects yet. Add them from the admin dashboard and mark them as Personal project.'
          }) %>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about section" id="about">
    <div class="marquee-strip" aria-label="Core marketing skills">
      <div class="marquee" role="presentation">
        <div class="marquee__track">
          <span>Storytelling</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Brand Strategy</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Creative Direction</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Consumer Insights</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Visual Identity</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Campaign Ideation</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Storytelling</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Brand Strategy</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Creative Direction</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Consumer Insights</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Visual Identity</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
          <span>Campaign Ideation</span>
          <span class="marquee__dot" aria-hidden="true">●</span>
        </div>
      </div>
    </div>
    <div class="container">
      <div class="about__grid">
        <div class="about__visual reveal-left">
          <div class="about__image-frame">
            <img class="about__image" src="/assets/profile.png" alt="Ana Machuca" width="1024" height="576" />
          </div>
          <div class="about__accent-shape" aria-hidden="true"></div>
        </div>
        <div class="about__text">
          <p class="section__label reveal-right">Hi, I'm Ana</p>
          <p class="about__description reveal-right">
            I grew up in Colombia, and developed an early appreciation for culture, community, and the role brands play in shaping everyday experiences and identity.
          </p>
          <p class="about__description reveal-right">
            I recently graduated from Hult International Business School with a degree in Marketing and a minor in Design. My education was rooted in a learn-by-doing approach, where adaptability and team work across diverse teams were part of everyday learning. Here, I've come to deeply value the power of multiple perspectives, especially when those perspectives are shaped by different cultures and lived experiences.
          </p>
          <p class="about__description reveal-right">
            Along the way, I developed a strong interest in the intersection of creativity and data using insights to inform ideas and creative thinking to bring them to life.
          </p>
          <p class="about__description reveal-right">
            I'm especially interested in how brands act like people, with distinct personalities, voices, and values. I enjoy translating that identity across touchpoints so audiences not only recognize a brand, but genuinely connect with it.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="contact section" id="contact">
    <div class="container">
      <div class="contact__content">
        <%- include('partials/contact-copy') %>
        <div class="contact__links reveal-scale">
          <% if (typeof resumeFileExists !== 'undefined' && resumeFileExists && resume && resume.path) { %>
          <% var _rp = String(resume.path || '').toLowerCase(); %>
          <% if (!_rp.endsWith('.md')) { %>
          <% var resumeBtnKind = _rp.endsWith('.docx') ? 'Word' : 'PDF'; %>
          <a href="<%= resume.path %>" class="btn btn--outline btn--large" download>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Download resume (<%= resumeBtnKind %>)
          </a>
          <% } %>
          <% } %>
          <a href="mailto:Anitamachuca2373@gmail.com?subject=Role%20inquiry" class="btn btn--primary btn--large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 4L12 13L2 4"/></svg>
            Email about a role
          </a>
          <a href="https://www.linkedin.com/in/anamachuca/" class="btn btn--outline btn--large" target="_blank" rel="noopener">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            Message on LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/main.js"></script>
</body>
</html>
