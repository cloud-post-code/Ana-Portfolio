<%- include('partials/footer') %>

<script src="/main.js"></script>
<script>
(function () {
  const cards = [
    {
      reason: 'Because you show up every day',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because your laugh lights up the room',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because you never stop growing',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because the world is better with you in it',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because your kindness is a superpower',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because you make hard things look beautiful',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because you choose love even when it\'s hard',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because your dreams deserve to come true',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because you inspire everyone around you',
      message: 'Message coming soon ♡',
    },
    {
      reason: 'Because simply being you is more than enough',
      message: 'Message coming soon ♡',
    },
  ];

  const modal        = document.getElementById('ohModal');
  const modalReason  = document.getElementById('ohModalReason');
  const modalMsg     = document.getElementById('ohModalMessage');
  const modalClose   = document.getElementById('ohModalClose');

  function openCard(item) {
    const idx  = parseInt(item.dataset.index, 10);
    const data = cards[idx];

    // Trigger envelope open animation
    item.classList.add('is-opening');

    // After card pops up, show the modal
    setTimeout(function () {
      modalReason.textContent  = data.reason;
      modalMsg.textContent     = data.message;
      modal.classList.add('is-visible');
    }, 600);
  }

  function closeModal() {
    modal.classList.remove('is-visible');
    // Reset all open envelopes after modal closes
    setTimeout(function () {
      document.querySelectorAll('.oh-item.is-opening').forEach(function (el) {
        el.classList.remove('is-opening');
      });
    }, 300);
  }

  document.querySelectorAll('.oh-item').forEach(function (item) {
    item.addEventListener('click', function () { openCard(item); });
    item.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openCard(item); }
    });
  });

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>
