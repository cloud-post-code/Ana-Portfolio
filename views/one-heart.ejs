<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>One Heart — Ana Machuca</title>
  <style>
    /* ── Page ── */
    .oh-page {
      min-height: 100vh;
      background: #fff0f4;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 80px 24px 60px;
      font-family: 'DM Sans', sans-serif;
    }

    .oh-page__title {
      font-family: 'Anton', sans-serif;
      font-size: clamp(2rem, 6vw, 3.5rem);
      color: #d63077;
      letter-spacing: 0.04em;
      margin-bottom: 8px;
      text-align: center;
    }

    .oh-page__sub {
      color: #c06080;
      font-size: 1rem;
      margin-bottom: 52px;
      text-align: center;
      font-style: italic;
    }

    /* ── Grid ── */
    .oh-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 32px;
      width: 100%;
      max-width: 900px;
    }

    /* ── Envelope wrapper ── */
    .oh-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      outline: none;
      -webkit-tap-highlight-color: transparent;
    }

    /* ── Envelope body ── */
    .oh-envelope {
      position: relative;
      width: 160px;
      height: 110px;
    }

    /* Back panel */
    .oh-env__back {
      position: absolute;
      inset: 0;
      background: #f9c8d8;
      border-radius: 4px 4px 6px 6px;
      box-shadow: 0 4px 18px rgba(214,48,119,.18), 0 1px 4px rgba(0,0,0,.08);
    }

    /* Left & right triangle flaps (sides) */
    .oh-env__side-left,
    .oh-env__side-right {
      position: absolute;
      bottom: 0;
      width: 0;
      height: 0;
    }
    .oh-env__side-left {
      left: 0;
      border-bottom: 55px solid #f0a8c0;
      border-right: 80px solid transparent;
    }
    .oh-env__side-right {
      right: 0;
      border-bottom: 55px solid #f0a8c0;
      border-left: 80px solid transparent;
    }

    /* Bottom flap */
    .oh-env__bottom {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 0;
      width: 0;
      border-left: 80px solid transparent;
      border-right: 80px solid transparent;
      border-bottom: 60px solid #e896b8;
    }

    /* Top flap — this folds open */
    .oh-env__top {
      position: absolute;
      top: 0; left: 0; right: 0;
      width: 0;
      height: 0;
      border-left: 80px solid transparent;
      border-right: 80px solid transparent;
      border-top: 62px solid #f4b6cc;
      transform-origin: top center;
      transition: transform 0.55s cubic-bezier(.4,0,.2,1);
      z-index: 4;
    }

    /* note on the envelope */
    .oh-env__note {
      position: absolute;
      top: 18px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 0.62rem;
      font-family: 'DM Sans', sans-serif;
      font-style: italic;
      color: #c0567e;
      white-space: nowrap;
      z-index: 5;
      pointer-events: none;
      letter-spacing: 0.02em;
    }

    /* ── Card sitting inside envelope ── */
    .oh-card {
      position: absolute;
      left: 10px;
      right: 10px;
      bottom: 8px;
      height: 86px;
      background: linear-gradient(135deg, #ff8fb1 0%, #ffb3cb 60%, #ffd6e4 100%);
      border-radius: 6px;
      z-index: 2;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 10px;
      transform: translateY(0);
      transition: transform 0.6s cubic-bezier(.4,0,.2,1) 0.2s;
      box-shadow: 0 2px 10px rgba(214,48,119,.2);
    }

    .oh-card__front,
    .oh-card__back {
      position: absolute;
      inset: 0;
      border-radius: 6px;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 10px;
      text-align: center;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
    }

    .oh-card__front {
      background: linear-gradient(135deg, #ff8fb1 0%, #ffb3cb 60%, #ffd6e4 100%);
    }

    .oh-card__back {
      background: linear-gradient(135deg, #ffd6e4 0%, #ffb3cb 60%, #ff8fb1 100%);
      transform: rotateY(180deg);
    }

    .oh-card__text {
      font-size: 0.62rem;
      font-weight: 600;
      color: #8b1a4a;
      line-height: 1.3;
      text-align: center;
    }

    .oh-card__heart {
      font-size: 1rem;
      margin-bottom: 4px;
    }

    /* ── OPEN STATE ── */
    .oh-item.is-open .oh-env__top {
      transform: rotateX(180deg);
    }

    .oh-item.is-open .oh-card {
      transform: translateY(-70px);
    }

    /* ── Flip state (card shows back) ── */
    .oh-card-inner {
      position: relative;
      width: 100%;
      height: 100%;
      transform-style: preserve-3d;
      transition: transform 0.5s cubic-bezier(.4,0,.2,1);
    }

    .oh-item.is-flipped .oh-card-inner {
      transform: rotateY(180deg);
    }

    /* ── Label under envelope ── */
    .oh-label {
      margin-top: 12px;
      font-size: 0.75rem;
      color: #d63077;
      font-weight: 500;
      text-align: center;
      line-height: 1.35;
    }

    /* ── Modal overlay for reading ── */
    .oh-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(255,200,220,0.45);
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .oh-modal-overlay.is-visible {
      opacity: 1;
      pointer-events: all;
    }

    .oh-modal {
      background: linear-gradient(145deg, #ff8fb1 0%, #ffb3cb 50%, #ffd6e4 100%);
      border-radius: 16px;
      width: min(420px, 90vw);
      min-height: 280px;
      padding: 40px 36px 36px;
      box-shadow: 0 24px 60px rgba(214,48,119,.35);
      transform: scale(0.88) translateY(24px);
      transition: transform 0.35s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      text-align: center;
    }

    .oh-modal-overlay.is-visible .oh-modal {
      transform: scale(1) translateY(0);
    }

    .oh-modal__close {
      position: absolute;
      top: 14px; right: 16px;
      background: none;
      border: none;
      font-size: 1.3rem;
      color: #8b1a4a;
      cursor: pointer;
      line-height: 1;
      padding: 4px;
    }

    .oh-modal__label {
      font-family: 'Anton', sans-serif;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      color: #c0567e;
      margin-bottom: 16px;
      text-transform: uppercase;
    }

    .oh-modal__message {
      font-size: 1.05rem;
      color: #5a0a2a;
      line-height: 1.65;
      font-weight: 500;
    }

    .oh-modal__heart {
      font-size: 2rem;
      display: block;
      margin-top: 20px;
    }

    /* ── Responsive ── */
    @media (max-width: 480px) {
      .oh-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
      .oh-envelope {
        width: 140px;
        height: 96px;
      }
      .oh-env__side-left { border-bottom-width: 48px; border-right-width: 70px; }
      .oh-env__side-right { border-bottom-width: 48px; border-left-width: 70px; }
      .oh-env__bottom { border-left-width: 70px; border-right-width: 70px; border-bottom-width: 52px; }
      .oh-env__top { border-left-width: 70px; border-right-width: 70px; border-top-width: 54px; }
      .oh-card { left: 8px; right: 8px; height: 76px; }
    }
  </style>
</head>
