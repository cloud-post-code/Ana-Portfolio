<!DOCTYPE html>
<html lang="en">
<head>
  <%- include('partials/head') %>
  <title>One Heart — Ana Machuca</title>
  <style>
    /* ── Page ── */
    .oh-page {
      min-height: 100vh;
      background: #fff0f4;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 80px 24px 60px;
      font-family: 'DM Sans', sans-serif;
    }

    .oh-page__title {
      font-family: 'Anton', sans-serif;
      font-size: clamp(2rem, 6vw, 3.5rem);
      color: #d63077;
      letter-spacing: 0.04em;
      margin-bottom: 8px;
      text-align: center;
    }

    .oh-page__sub {
      color: #c06080;
      font-size: 1rem;
      margin-bottom: 52px;
      text-align: center;
      font-style: italic;
    }

    /* ── Grid ── */
    .oh-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 36px 28px;
      width: 100%;
      max-width: 860px;
    }

    /* ── Envelope wrapper ── */
    .oh-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      cursor: pointer;
      outline: none;
      -webkit-tap-highlight-color: transparent;
    }

    /* ── Envelope — perspective wrapper ── */
    .oh-envelope {
      position: relative;
      width: 160px;
      height: 110px;
      perspective: 600px;
      transition: transform 0.18s ease;
    }

    .oh-item:hover .oh-envelope {
      transform: scale(1.04);
    }

    /* Back panel — the envelope body */
    .oh-env__back {
      position: absolute;
      inset: 0;
      background: #f9c8d8;
      border-radius: 4px 4px 6px 6px;
      box-shadow: 0 6px 22px rgba(214,48,119,.2), 0 1px 4px rgba(0,0,0,.07);
      overflow: hidden;
    }

    /* Left side flap */
    .oh-env__side-left {
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 0;
      border-bottom: 55px solid #f0a8c0;
      border-right: 80px solid transparent;
    }

    /* Right side flap */
    .oh-env__side-right {
      position: absolute;
      bottom: 0; right: 0;
      width: 0; height: 0;
      border-bottom: 55px solid #f0a8c0;
      border-left: 80px solid transparent;
    }

    /* Bottom flap */
    .oh-env__bottom {
      position: absolute;
      bottom: 0; left: 0;
      width: 0; height: 0;
      border-left: 80px solid transparent;
      border-right: 80px solid transparent;
      border-bottom: 60px solid #e896b8;
    }

    /* Top flap — folds open with rotateX */
    .oh-env__top {
      position: absolute;
      top: 0; left: 0;
      width: 0; height: 0;
      border-left: 80px solid transparent;
      border-right: 80px solid transparent;
      border-top: 62px solid #f4b6cc;
      transform-origin: top center;
      transform-style: preserve-3d;
      transition: transform 0.55s cubic-bezier(.4,0,.2,1);
      z-index: 4;
    }

    /* Animating state — flap folds back */
    .oh-item.is-opening .oh-env__top {
      transform: rotateX(180deg);
    }

    /* ── Card — hidden inside envelope, slides up on open ── */
    .oh-card {
      position: absolute;
      left: 10px;
      right: 10px;
      /* sits fully inside — bottom of card flush with envelope bottom */
      bottom: 6px;
      height: 90px;
      background: linear-gradient(135deg, #ff8fb1 0%, #ffb3cb 60%, #ffd6e4 100%);
      border-radius: 6px;
      z-index: 2;
      box-shadow: 0 2px 10px rgba(214,48,119,.2);
      /* start clipped inside envelope — overflow:hidden on .oh-env__back handles this */
      transform: translateY(0px);
      opacity: 0;
      transition:
        transform 0.55s cubic-bezier(.34,1.4,.64,1) 0.25s,
        opacity   0.3s ease 0.25s;
    }

    .oh-item.is-opening .oh-card {
      transform: translateY(-105px);
      opacity: 1;
    }

    /* ── Modal overlay ── */
    .oh-modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(255, 200, 220, 0.5);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .oh-modal-overlay.is-visible {
      opacity: 1;
      pointer-events: all;
    }

    /* Modal card — styled like a big pink card */
    .oh-modal {
      background: linear-gradient(145deg, #ff8fb1 0%, #ffb3cb 50%, #ffd6e4 100%);
      border-radius: 20px;
      width: min(420px, 88vw);
      padding: 48px 40px 40px;
      box-shadow: 0 28px 70px rgba(214,48,119,.38);
      transform: scale(0.82) translateY(32px);
      transition: transform 0.42s cubic-bezier(.34,1.56,.64,1);
      position: relative;
      text-align: center;
    }

    .oh-modal-overlay.is-visible .oh-modal {
      transform: scale(1) translateY(0);
    }

    .oh-modal__close {
      position: absolute;
      top: 16px; right: 18px;
      background: none;
      border: none;
      font-size: 1.2rem;
      color: #8b1a4a;
      cursor: pointer;
      line-height: 1;
      padding: 6px;
      opacity: 0.7;
      transition: opacity 0.15s;
    }
    .oh-modal__close:hover { opacity: 1; }

    .oh-modal__reason {
      font-family: 'Anton', sans-serif;
      font-size: 1.15rem;
      color: #8b1a4a;
      letter-spacing: 0.02em;
      margin-bottom: 20px;
      line-height: 1.3;
    }

    .oh-modal__divider {
      width: 40px;
      height: 2px;
      background: rgba(139,26,74,.25);
      margin: 0 auto 20px;
      border-radius: 2px;
    }

    .oh-modal__message {
      font-size: 1rem;
      color: #5a0a2a;
      line-height: 1.7;
      font-weight: 500;
    }

    .oh-modal__heart {
      font-size: 1.8rem;
      display: block;
      margin-top: 24px;
    }

    /* ── Responsive ── */
    @media (max-width: 520px) {
      .oh-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 24px 16px;
      }
      .oh-envelope { width: 140px; height: 96px; }
      .oh-env__side-left  { border-bottom-width: 48px; border-right-width: 70px; }
      .oh-env__side-right { border-bottom-width: 48px; border-left-width: 70px; }
      .oh-env__bottom { border-left-width: 70px; border-right-width: 70px; border-bottom-width: 52px; }
      .oh-env__top    { border-left-width: 70px; border-right-width: 70px; border-top-width: 54px; }
      .oh-card { left: 8px; right: 8px; height: 78px; }
      .oh-item.is-opening .oh-card { transform: translateY(-92px); }
    }
  </style>
</head>
<body>

