<script src="/main.js"></script>
<script>
(function () {
  // Back-of-card messages — fill these in as you create them
  const messages = [
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
    'Message coming soon ♡',
  ];

  const frontReasons = [
    'Because you show up every day',
    'Because your laugh lights up the room',
    'Because you never stop growing',
    'Because the world is better with you in it',
    'Because your kindness is a superpower',
    'Because you make hard things look beautiful',
    'Because you choose love even when it\'s hard',
    'Because your dreams deserve to come true',
    'Because you inspire everyone around you',
    'Because simply being you is more than enough',
  ];

  const modal = document.getElementById('ohModal');
  const modalMsg = document.getElementById('ohModalMessage');
  const modalClose = document.getElementById('ohModalClose');

  let currentOpen = null;

  function openEnvelope(item) {
    const idx = parseInt(item.dataset.index, 10);

    // If something else is open, close it first
    if (currentOpen && currentOpen !== item) {
      currentOpen.classList.remove('is-open', 'is-flipped');
      currentOpen = null;
    }

    if (item.classList.contains('is-open')) {
      // second click → show modal with back message
      const msg = messages[idx];
      modalMsg.textContent = msg;
      modal.classList.add('is-visible');
      item.classList.add('is-flipped');
    } else {
      // first click → open envelope
      item.classList.add('is-open');
      currentOpen = item;
    }
  }

  document.querySelectorAll('.oh-item').forEach(function (item) {
    item.addEventListener('click', function () { openEnvelope(item); });
    item.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        openEnvelope(item);
      }
    });
  });

  function closeModal() {
    modal.classList.remove('is-visible');
  }

  modalClose.addEventListener('click', closeModal);
  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeModal();
  });
})();
</script>
